  branchId             String?

  tripSession          TripSession      @relation(fields: [tripSessionId], references: [id], onDelete: Cascade)
  @@index([schoolId])
}

model NotificationStatusLog {
  id             String                     @id @default(uuid())
  notificationId String
  status         NotificationDeliveryStatus
  changedAt      DateTime                   @default(now())
  details        String?

  notification   TransportNotification      @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  @@index([notificationId])
}

enum RuleStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  SUPERSEDED
}

enum KYCStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ClaimStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  SETTLED
  CANCELLED
}

enum PayrollEventType {
  PAYROLL_CREATED
  PAYROLL_LOCKED
  PAYROLL_APPROVED
  PF_CALCULATED
  ECR_GENERATED
  CHALLAN_PAID
}

model EstablishmentConfig {
  id                   String          @id @default(uuid())
  schoolId             String
  branchId             String?         @unique
  legalName            String
  pan                  String
  tan                  String
  gst                  String?
  epfoEstablishmentCode String
  epfoRegistrationDate DateTime
  esicNumber           String?
  labourLicenseNumber  String?
  bankAccount          String
  authorizedSignatory  String
  dscDetails           String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@unique([schoolId, epfoEstablishmentCode])
  @@index([schoolId])
}

model StatutoryConfigHeader {
  id            String             @id @default(uuid())
  schoolId      String
  type          String             // "EPFO", "ESIC", "PT"
  scope         String             // "PLATFORM", "TENANT", "BRANCH", "EMPLOYEE"
  scopeId       String             // Maps to Tenant ID, Branch ID, or Employee ID
  version       Int
  status        RuleStatus         @default(DRAFT)
  createdBy     String
  approvedBy    String?
  approvedDate  DateTime?
  circularNo    String?
  circularPdf   String?
  rollbackVer   Int?
