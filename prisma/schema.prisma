// School-specific calendar — holidays, half-days, working Saturdays
model SchoolCalendar {
  id         String   @id @default(uuid())
  schoolId   String
  branchId   String?  // null = applies to whole school; set = branch-specific
  date       DateTime
  type       String   // "HOLIDAY" | "HALF_DAY" | "WORKING_SATURDAY" | "WORKING_DAY"
  reason     String
  source     String   @default("SCHOOL") // "NATIONAL" | "STATE" | "SCHOOL" | "UNPLANNED"
  isOverride Boolean  @default(false)    // true = admin manually changed a pre-loaded holiday
  createdBy  String?
  createdAt  DateTime @default(now())
  school     School   @relation(fields: [schoolId], references: [id])
  branch     Branch?  @relation(fields: [branchId], references: [id])

  @@unique([schoolId, branchId, date])
  @@index([schoolId, date])
  @@index([schoolId, type])

  @@index([branchId])
}

// Master list of public holidays — maintained by ERP admin once per year per state
model PublicHolidayMaster {
  id        String   @id @default(uuid())
  country   String   @default("India")
  state     String?  // null = national holiday applies to all states
  year      Int
  date      DateTime
  name      String
  type      String   @default("PUBLIC") // "PUBLIC" | "RESTRICTED" | "OPTIONAL"
  createdAt DateTime @default(now())

  @@unique([country, state, year, date])
  @@index([country, state, year])
}

