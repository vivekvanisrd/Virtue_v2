// ==========================================
// TRANSPORT V2 MODELS
// ==========================================

model Driver {
  id                  String             @id @default(uuid())
  name                String
  phone               String             @unique
  licenseNo           String             @unique
  passwordHash        String
  status              String             @default("Active") // Active, Inactive, Suspended
  schoolId            String
  branchId            String?
  lastLoginAt         DateTime?
  deviceId            String?
  refreshTokenVersion Int                @default(0)
  lastSeenAt          DateTime?
  failedLoginAttempts Int                @default(0)
  accountLockedUntil  DateTime?
  isDeleted           Boolean            @default(false)
  deletedAt           DateTime?
  branch              Branch?            @relation(fields: [branchId], references: [id])
  school              School             @relation(fields: [schoolId], references: [id])
  assignments         DriverAssignment[]
  tripSessions        TripSession[]
  incidents           VehicleIncident[]
  deviceLogs          DriverDeviceLog[]
  loginAudits         DriverLoginAudit[]
  refreshSessions       DriverRefreshSession[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  documents           Json?              // Stores references to photoUrl, licenseScanUrl, etc.

  @@index([schoolId])
  @@index([branchId])
}

model DriverAssignment {
  id         String    @id @default(uuid())
  driverId   String
  vehicleId  String
  routeId    String
  schoolId   String
  branchId   String?
  status     String    @default("Active") // Active, Historical
  isDeleted  Boolean   @default(false)
  deletedAt  DateTime?
  assignedAt DateTime  @default(now())
  driver     Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle    Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  route      Route     @relation(fields: [routeId], references: [id], onDelete: Cascade)
  school     School    @relation(fields: [schoolId], references: [id])

  @@unique([driverId, vehicleId, routeId, status])
  @@index([schoolId])
  @@index([branchId])

  @@index([vehicleId])
  @@index([routeId])
}

model StudentTransport {
  id           String      @id @default(uuid())
  studentId    String      @unique
  routeId      String
  pickupStopId String
  dropStopId   String
  monthlyFee   Decimal     @db.Decimal(10, 2)
  status       String      @default("Active") // Active, Suspended
  schoolId     String
  branchId     String?
  isDeleted    Boolean     @default(false)
  deletedAt    DateTime?
  student      Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  route        Route       @relation(fields: [routeId], references: [id])
  pickupStop   VehicleStop @relation("PickupStopV2", fields: [pickupStopId], references: [id])
  dropStop     VehicleStop @relation("DropStopV2", fields: [dropStopId], references: [id])
  school       School      @relation(fields: [schoolId], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([studentId])
  @@index([routeId])
  @@index([schoolId])
  @@index([branchId])

  @@index([pickupStopId])
  @@index([dropStopId])
}

model TripSession {
  id           String          @id @default(uuid())
  routeId      String
  vehicleId    String
  driverId     String
  tripType     String          // PICKUP, DROP
  status       String          @default("SCHEDULED") // SCHEDULED, ACTIVE, COMPLETED, CANCELLED
  startedAt       DateTime?
  endedAt         DateTime?
  tripHeartbeatAt DateTime?
  schoolId     String
  branchId     String?
  isDeleted    Boolean         @default(false)
  deletedAt    DateTime?
  route        Route           @relation(fields: [routeId], references: [id])
  vehicle      Vehicle         @relation(fields: [vehicleId], references: [id])
  driver       Driver          @relation(fields: [driverId], references: [id])
  school       School          @relation(fields: [schoolId], references: [id])
  attendance   BusAttendance[]
  incidents    VehicleIncident[]
  simulationJob SimulationJob?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([routeId])
  @@index([vehicleId])
  @@index([driverId])
  @@index([schoolId])
  @@index([branchId])
}

/// 💡 Redis is the primary live store for real-time telemetry.
/// This PostgreSQL table is used purely as an optional failover/fallback cache.
model VehicleGPSLive {
  vehicleId       String   @id
  schoolId        String
  branchId        String?
  latitude        Float
  longitude       Float
  speed           Float    @default(0.0)
  heading         Float    @default(0.0)
  sequenceNo      Int?
  updatedAt       DateTime @updatedAt
  serverTimestamp DateTime @default(now())
  clientTimestamp DateTime?
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([branchId])
}

/// 📅 GPS Log Retention Policy:
/// Keep recent 90 days in PostgreSQL, older logs should be archived to compressed storage.
model VehicleGPSLog {
  id              String   @id @default(uuid())
  vehicleId       String
  tripSessionId   String
  schoolId        String
  branchId        String?
  latitude        Float
  longitude       Float
  speed           Float    @default(0.0)
  heading         Float    @default(0.0)
  sequenceNo      Int?
  timestamp       DateTime @default(now())
  serverTimestamp DateTime @default(now())
  clientTimestamp DateTime?

  @@index([vehicleId, timestamp])
  @@index([tripSessionId])
  @@index([schoolId])
  @@index([branchId])
}

