  @@index([effectiveFrom, effectiveTo])
}

model StatutoryRule {
  id            String             @id @default(uuid())
  configId      String
  parameter     String             // e.g. "PF_RATE", "WAGE_CEILING"
  value         String
  datatype      String             // "DECIMAL", "INTEGER", "STRING", "BOOLEAN"
  configHeader  StatutoryConfigHeader @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, parameter])
}

model SalaryComponent {
  id                      String   @id @default(uuid())
  schoolId                String
  name                    String   @unique
  isIncludedInBasic       Boolean  @default(false)
  isIncludedInDA          Boolean  @default(false)
  isIncludedInGross       Boolean  @default(true)
  isIncludedInCTC         Boolean  @default(true)
  isPFEligible            Boolean  @default(false)
  isEPSEligible           Boolean  @default(false)
  isEDLIEligible          Boolean  @default(false)
  isESICEligible          Boolean  @default(false)
  isPTEligible            Boolean  @default(false)
  isLWFEligible           Boolean  @default(false)
  isBonusEligible         Boolean  @default(false)
  isGratuityEligible      Boolean  @default(false)
  isLeaveEncashEligible   Boolean  @default(false)
  isIncomeTaxEligible     Boolean  @default(true)
  createdAt               DateTime @default(now())

  @@index([schoolId])
}

model UANMaster {
  id             String          @id @default(uuid())
  staffId        String          @unique
  uan            String          @unique
  oldUan         String?
  mergedUan      String?
  transferredUan String?
  status         String          // "ACTIVE", "MERGED", "INACTIVE"
  remarks        String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([uan])
}

model NomineeMaster {
  id             String          @id @default(uuid())
  staffId        String
  name           String
  relationship   String
  dob            DateTime
  guardianName   String?
  percentage     Decimal         @db.Decimal(5, 2)
  address        String
  mobile         String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())

  @@index([staffId])
}

model KYCMaster {
  id             String          @id @default(uuid())
  staffId        String
  documentType   String          // "AADHAAR", "PAN", "BANK_ACCOUNT", "PASSPORT", "DL"
  documentNumber String          // Encrypted in production
  verifiedAt     DateTime?
  verifiedBy     String?
  status         KYCStatus       @default(PENDING)
  createdAt      DateTime        @default(now())

  @@unique([staffId, documentType])
  @@index([staffId])
}

model UniversalDocument {
  id          String                   @id @default(uuid())
  schoolId    String
  title       String
  tag         String                   // "UAN_KYC", "CLAIM_ATTACHMENT"
  versions    UniversalDocumentVersion[]
  links       UniversalDocumentLink[]
  createdAt   DateTime                 @default(now())
}

model UniversalDocumentVersion {
  id          String             @id @default(uuid())
  documentId  String
  version     Int
  fileUrl     String
  uploadedBy  String
  createdAt   DateTime           @default(now())
  document    UniversalDocument  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model UniversalDocumentLink {
  id          String             @id @default(uuid())
  documentId  String
  entityType  String             // "STAFF", "CLAIM", "NOMINEE"
  entityId    String
  document    UniversalDocument  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([entityType, entityId])
}

model PayrollSnapshot {
  id             String          @id @default(uuid())
  payrollRunId   String
  staffId        String
  frozenData     Json            // Frozen metadata, basic settings, and rules
  hash           String          // Cryptographic SHA-256 validation hash
  signature      String?         // Digital Signatures
  createdAt      DateTime        @default(now())

  @@unique([payrollRunId, staffId])
  @@index([payrollRunId])
}

model CalculationTrace {
  id             String          @id @default(uuid())
  payrollRunId   String
  staffId        String
  step           String          // e.g. "PF_WAGE", "EMPLOYEE_PF"
  formula        String
  input          String          // Serialized input parameters
  output         String
  ruleVersion    Int
  timestamp      DateTime        @default(now())

  @@index([payrollRunId, staffId])
}

model EPFOWithdrawalClaim {
  id              String         @id @default(uuid())
  staffId         String
  claimNumber     String         @unique
  category        String         // "ILLNESS", "EDUCATION", "MARRIAGE", "HOUSING"
  amountRequested Decimal        @db.Decimal(12, 2)
  amountApproved  Decimal?       @db.Decimal(12, 2)
  applicationDate DateTime       @default(now())
  settlementDate  DateTime?
  status          ClaimStatus    @default(PENDING)
  rejectionReason String?
  createdAt       DateTime       @default(now())

  @@index([staffId])
}

model ComplianceException {
  id             String          @id @default(uuid())
  schoolId       String
  payrollRunId   String?
  staffId        String?
  code           String          // "DUPLICATE_UAN", "MISSING_AADHAAR", "NEGATIVE_PF"
  message        String
  resolvedAt     DateTime?
  resolvedBy     String?
  createdAt      DateTime        @default(now())

  @@index([schoolId, resolvedAt])
}

model PayrollEventLog {
  id             String          @id @default(uuid())
  payrollRunId   String
  eventType      PayrollEventType
  metadata       Json?
  userId         String
  ipAddress      String
  userAgent      String
  timestamp      DateTime        @default(now())

  @@index([payrollRunId])
}

model StatutoryAuditLog {
  id             String          @id @default(uuid())
  userId         String
  actionType     String          // "INSERT", "UPDATE", "DELETE", "ROLLBACK"
  tableName      String
  recordId       String
  oldValue       Json?
  newValue       Json?
  reason         String?
  ipAddress      String
  userAgent      String
  sessionToken   String?
  hash           String          // Forensic hash check
  timestamp      DateTime        @default(now())

  @@index([tableName, recordId])
}

model AIModelRegistry {
  id                  String   @id @default(uuid())
  provider            String   // "OLLAMA", "GEMINI", "OPENAI", "CLAUDE"
  modelName           String   @unique
  contextWindow       Int
  priority            Int      @default(1)
  isEnabled           Boolean  @default(true)
  isDefault           Boolean  @default(false)
  supportsJson        Boolean  @default(true)
  supportsImages      Boolean  @default(false)
  supportsEmbeddings  Boolean  @default(true)
  supportsTools       Boolean  @default(false)
  createdAt           DateTime @default(now())
}

model AIPromptTemplate {
  id            String      @id @default(uuid())
  businessId    String
  name          String      @unique // e.g. "INVOICE_OCR_PROMPT"
  module        String      // "FINANCE", "INVENTORY", "CRM"
  category      String
  version       Int         @default(1)
  language      String      @default("en")
  templateText  String      @db.Text
  status        RuleStatus  @default(DRAFT)
  variables     String[]    // List of placeholder keys
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([businessId, module])
}

model EmbeddingDocument {
  id             String           @id @default(uuid())
  businessId     String
  title          String
  category       String           // "INVOICE", "POLICY", "VOUCHER"
  embeddingModel String           // e.g. "nomic-embed-text"
  dimension      Int              // e.g. 768, 1536
  version        Int              @default(1)
  createdAt      DateTime         @default(now())
  chunks         EmbeddingChunk[]

  @@index([businessId, category])
}

model EmbeddingChunk {
  id          String             @id @default(uuid())
  documentId  String
  content     String             @db.Text
  embedding   Unsupported("vector(768)")? // Nomic default dimension is 768
  document    EmbeddingDocument  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model KnowledgeEntity {
  id          String              @id @default(uuid())
  businessId  String
  name        String
  type        String              // "PRODUCT", "VENDOR", "CUSTOMER", "INVOICE"
  incoming    KnowledgeRelation[] @relation("IncomingRelation")
  outgoing    KnowledgeRelation[] @relation("OutgoingRelation")

  @@unique([businessId, name, type])
  @@index([businessId])
}

model KnowledgeRelation {
  id          String          @id @default(uuid())
  sourceId    String
  targetId    String
  relation    String          // "VENDS", "BUYS", "CONTAINS"
  confidence  Float           @default(1.0)
  source      KnowledgeEntity @relation("OutgoingRelation", fields: [sourceId], references: [id], onDelete: Cascade)
  target      KnowledgeEntity @relation("IncomingRelation", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, relation])
}

model AICallLog {
  id             String    @id @default(uuid())
  businessId     String
  module         String
  provider       String
  modelName      String
  promptVersion  Int?
  latencyMs      Int
  tokenCount     Int?
  responseLength Int
  isCacheHit     Boolean   @default(false)
  isFallbackUsed Boolean   @default(false)
  errors         String?   @db.Text
  createdAt      DateTime  @default(now())

  @@index([businessId, module])
  @@index([createdAt])
}

// ==========================================
//           PARENTS MODULE MODELS
// ==========================================

model Guardian {
  id             String            @id @default(uuid())
  firstName      String
  lastName       String?
  phone          String            @unique
  email          String?
  aadhaarNumber  String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  schoolId       String
  
  // Relations
  auth             GuardianAuth?
  students         StudentGuardian[]
  acknowledgements NoticeAcknowledgement[]
  feedbacks        Feedback[]
  profileRequests  ProfileChangeRequest[]
  conversations    Conversation[]
  appointments     Appointment[]
}

model StudentGuardian {
  id                      String   @id @default(uuid())
  studentId               String
  guardianId              String
  relationType            String   // e.g. "FATHER", "MOTHER", "GRANDPARENT", "GUARDIAN"
  isPrimaryGuardian       Boolean  @default(false)
  feeResponsibility       Boolean  @default(false)
  emergencyContact        Boolean  @default(false)
  pickupPermission        Boolean  @default(false)
  portalAccess            Boolean  @default(true)
  communicationPreference String   @default("SMS") // "SMS", "WHATSAPP", "EMAIL", "NONE"
  activeStatus            String   @default("ACTIVE") // "ACTIVE", "INACTIVE"
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  schoolId                String
  branchId                String

  // Relations
  student                 Student  @relation(fields: [studentId], references: [id])
  guardian                Guardian @relation(fields: [guardianId], references: [id])

  @@unique([studentId, guardianId])
  @@index([guardianId])
  @@index([studentId])
}

model GuardianAuth {
  id             String            @id @default(uuid())
  guardianId     String            @unique
  passwordHash   String?           // Optional password backup
  failedAttempts Int               @default(0)
  lockedUntil    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  
  // Relations
  guardian       Guardian          @relation(fields: [guardianId], references: [id])
  otps           GuardianOTP[]
  sessions       GuardianSession[]
}

model GuardianOTP {
  id             String            @id @default(uuid())
  authId         String
  phone          String
  otpHash        String            // Secure SHA-256 hash of OTP
  purpose        String            // "LOGIN", "PAYMENT_AUTH", "PROFILE_EDIT"
  expiresAt      DateTime          @db.Timestamptz(6)
  verifiedAt     DateTime?         @db.Timestamptz(6)
  attemptCount   Int               @default(0)
  ipAddress      String?
  deviceInfo     String?
  createdAt      DateTime          @default(now())

  // Relations
  auth           GuardianAuth      @relation(fields: [authId], references: [id])
  
  @@index([authId])
}

model GuardianSession {
  id             String            @id @default(uuid())
  authId         String
  sessionToken   String            @unique
  refreshToken   String            @unique
  deviceName     String?
  deviceType     String?           // "MOBILE", "DESKTOP", "TABLET"
  browser        String?
  ipAddress      String?
  lastLogin      DateTime          @default(now())
  expiresAt      DateTime          @db.Timestamptz(6)
  revokedAt      DateTime?         @db.Timestamptz(6)
  createdAt      DateTime          @default(now())

  // Relations
  auth           GuardianAuth      @relation(fields: [authId], references: [id])
  
  @@index([authId])
}

model Homework {
  id             String               @id @default(uuid())
  schoolId       String
  branchId       String
  academicYearId String
  classId        String
  sectionId      String?
  subjectId      String
  teacherId      String
  homeworkDate   DateTime             @db.Timestamptz(6)
  dueDate        DateTime             @db.Timestamptz(6)
  title          String
  description    String
  attachment     String?              // URL/Key of attachment
  status         String               @default("PUBLISHED") // "DRAFT", "PUBLISHED", "CLOSED"
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  createdBy      String
  updatedBy      String

  // Relations
  submissions    HomeworkSubmission[]
  class          Class                @relation(fields: [classId], references: [id])
  section        Section?             @relation(fields: [sectionId], references: [id])
}

model HomeworkSubmission {
  id               String      @id @default(uuid())
  homeworkId       String
  studentId        String
  submittedAt      DateTime    @default(now()) @db.Timestamptz(6)
  attachment       String?
  teacherRemarks   String?
  marks            Decimal?    @db.Decimal(5, 2)
  submissionStatus String      @default("SUBMITTED") // "SUBMITTED", "EVALUATED", "LATE"
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  // Relations
  homework         Homework    @relation(fields: [homeworkId], references: [id])
  student          Student     @relation(fields: [studentId], references: [id])

  @@unique([homeworkId, studentId])
}

model Notice {
  id                     String                 @id @default(uuid())
  schoolId               String
  branchId               String
  title                  String
  content                String
  audienceType           String                 // "ALL", "PARENTS", "STUDENTS", "TEACHERS", "CLASS", "SECTION", "TRANSPORT"
  targetClassId          String?
  targetSectionId        String?
  publishFrom            DateTime               @db.Timestamptz(6)
  publishTill            DateTime               @db.Timestamptz(6)
  priority               String                 @default("NORMAL") // "LOW", "NORMAL", "HIGH", "CRITICAL"
  requiresAcknowledgement Boolean               @default(false)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  createdBy              String

  // Relations
  attachments            NoticeAttachment[]
  acknowledgements       NoticeAcknowledgement[]
}

model NoticeAttachment {
  id        String   @id @default(uuid())
  noticeId  String
  fileUrl   String
  fileName  String
  createdAt DateTime @default(now())

  // Relations
  notice    Notice   @relation(fields: [noticeId], references: [id])
}

model NoticeAcknowledgement {
  id              String   @id @default(uuid())
  noticeId        String
  guardianId      String
  acknowledgedAt  DateTime @default(now()) @db.Timestamptz(6)
  ipAddress       String?
  deviceInfo      String?

  // Relations
  notice          Notice   @relation(fields: [noticeId], references: [id])
  guardian        Guardian @relation(fields: [guardianId], references: [id])

  @@unique([noticeId, guardianId])
}

model Feedback {
  id               String   @id @default(uuid())
  schoolId         String
  branchId         String
  studentId        String?
  guardianId       String
  category         String   // "ACADEMIC", "TEACHER", "SCHOOL", "TRANSPORT", "APP", "FEE", "GENERAL"
  targetType       String   // "Teacher", "Branch", "School", "Application"
  targetId         String?  // UUID of the teacher or branch
  rating           Int?     // 1 to 5 stars
  comment          String
  isAnonymous      Boolean  @default(false)
  moderationStatus String   @default("PENDING") // "PENDING", "APPROVED", "REJECTED"
  createdAt        DateTime @default(now())

  // Relations
  student          Student? @relation(fields: [studentId], references: [id])
  guardian         Guardian @relation(fields: [guardianId], references: [id])
}

model ProfileChangeRequest {
  id           String    @id @default(uuid())
  studentId    String?
  guardianId   String
  requestType  String    // "PHONE", "EMAIL", "ADDRESS", "PHOTO", "EMERGENCY_CONTACT"
  oldValue     String
  newValue     String
  attachment   String?   // Verification document URL
  status       String    @default("PENDING") // "PENDING", "APPROVED", "REJECTED"
  approvedBy   String?
  approvedAt   DateTime? @db.Timestamptz(6)
  remarks      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  schoolId     String
  branchId     String

  // Relations
  student      Student?  @relation(fields: [studentId], references: [id])
  guardian     Guardian  @relation(fields: [guardianId], references: [id])
}

model Conversation {
  id           String       @id @default(uuid())
  schoolId     String
  branchId     String
  teacherId    String
  guardianId   String
  isClosed     Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  messages     Message[]
  guardian     Guardian     @relation(fields: [guardianId], references: [id])
  
  @@unique([teacherId, guardianId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderType     String       // "TEACHER", "GUARDIAN"
  senderId       String
  content        String
  attachment     String?
  readAt         DateTime?    @db.Timestamptz(6)
  createdAt      DateTime     @default(now())

  // Relations
  conversation   Conversation @relation(fields: [conversationId], references: [id])
}

model Appointment {
  id             String    @id @default(uuid())
  schoolId       String
  branchId       String
  guardianId     String
  teacherId      String
  meetingType    String    // "ONLINE", "OFFLINE"
  scheduledDate  DateTime  @db.Timestamptz(6)
  durationMin    Int       @default(15)
  purpose        String
  status         String    @default("PENDING") // "PENDING", "ACCEPTED", "DECLINED", "COMPLETED"
  meetingLink    String?   // Zoom/Meet URL
  remarks        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  guardian       Guardian  @relation(fields: [guardianId], references: [id])
}




