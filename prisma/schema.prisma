generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model School {
  id                    String                       @id
  name                  String
  code                  String                       @unique
  address               String?
  phone                 String?
  email                 String?
  logo                  String?
  highestClass          String?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  status                String                       @default("Active")
  dnaVersion            String                       @default("v1")
  isGenesis             Boolean                      @default(false)
  metadata              Json?
  tenantId              String?
  country               String?   @default("India")
  state                 String?
  saturdayPolicy        String?   @default("ALL_OFF")
  academicYearStart     Int?      @default(6)
  academicYearEnd       Int?      @default(3)
  calendars             SchoolCalendar[]
  academicHist          StudentAcademicYear[]
  academicRecs          AcademicRecord[]
  academicYears         AcademicYear[]
  activityLogs          ActivityLog[]
  Address               Address[]
  attendancePolicies    AttendancePolicy[]
  BankDetail            BankDetail[]
  bankStatements        BankStatement[]
  bankStatementEntries  BankStatementEntry[]
  branches              Branch[]
  accounts              ChartOfAccount[]
  Class                 Class[]
  collections           Collection[]
  creditNotes           CreditNote[]
  discounts             Discount[]
  discountTypes         DiscountType[]
  docRecords            Document[]
  staffDocuments        StaffDocument[]
  enquiries             Enquiry[]
  examResults           ExamResult[]
  examTypes             ExamType[]
  FamilyDetail          FamilyDetail[]
  feeComponents         FeeComponentMaster[]
  backboneInvoices      FeeInvoice[]
  feeStructures         FeeStructure[]
  feeTemplateComponents FeeTemplateComponent[]
  financialAuditLogs    FinancialAuditLog[]
  finRecords            FinancialRecord[]
  financialYears        FinancialYear[]
  gradeScales           GradeScale[]
  journals              JournalEntry[]
  ledgerEntries         LedgerEntry[]
  MedicalRecord         MedicalRecord[]
  notifications         Notification[]
  payrollRuns           PayrollRun[]
  PreviousSchool        PreviousSchool[]
  routes                Route[]
  SalaryRevision        SalaryRevision[]
  SalarySlip            SalarySlip[]
  Section               Section[]
  SovereignEvent        SovereignEvent[]
  sovereignRoles        SovereignRole[]
  staff                 Staff[]
  approvalRequests      ApprovalRequest[]
  StaffAdvance          StaffAdvance[]
  StaffAsset            StaffAsset[]
  StaffAttendance       StaffAttendance[]
  StaffBank             StaffBank[]
  staffCategories       StaffCategory[]
  staffDepartments      StaffDepartment[]
  StaffKYC              StaffKYC[]
  StaffProfessional     StaffProfessional[]
  StaffStatutory        StaffStatutory[]
  students              Student[]
  attendance            StudentAttendance[]
  studentFeeComponents  StudentFeeComponent[]
  transportAssignments  StudentTransportAssignment[]
  subjects              Subject[]
  counters              TenancyCounter[]
  TransportAssignment   TransportAssignment[]
  TransportDetail       TransportDetail[]
  TransportStop         TransportStop[]
  unlockRequests        UnlockRequest[]

  biometricDevices      BiometricDevice[]

  // V2 Transport Relations
  drivers               Driver[]
  driverAssignments     DriverAssignment[]
  studentTransports     StudentTransport[]
  tripSessions          TripSession[]
  vehicleIncidents      VehicleIncident[]
  vehicleMaintenances   VehicleMaintenance[]
  vehicleStops          VehicleStop[]
  driverDeviceLogs      DriverDeviceLog[]
  driverLoginAudits     DriverLoginAudit[]
  driverRefreshSessions DriverRefreshSession[]
  transportSettings     TransportSettings?
}

model PlatformAdmin {
  id                   String                 @id @default(uuid())
  name                 String
  email                String                 @unique
  username             String                 @unique
  passwordHash         String
  metadata             Json?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  PlatformAcademicYear PlatformAcademicYear[]
  PlatformClass        PlatformClass[]
}

model PlatformClass {
  id              String            @id @default(uuid())
  name            String            @unique
  level           Int               @unique
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  platformAdminId String?
  platformAdmin   PlatformAdmin?    @relation(fields: [platformAdminId], references: [id])
  sections        PlatformSection[]

  @@index([platformAdminId])
}

model PlatformSection {
  id              String        @id @default(uuid())
  name            String
  platformClassId String
  platformClass   PlatformClass @relation(fields: [platformClassId], references: [id])

  @@index([platformClassId])
}

model PlatformAcademicYear {
  id              String         @id @default(uuid())
  name            String         @unique
  startMonth      Int
  endMonth        Int
  createdAt       DateTime       @default(now())
  platformAdminId String?
  platformAdmin   PlatformAdmin? @relation(fields: [platformAdminId], references: [id])

  @@index([platformAdminId])
}

model Branch {
  id                   String                 @id
  schoolId             String
  name                 String
  code                 String
  address              String?
  phone                String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  status               String                 @default("Active")
  isGenesis            Boolean                @default(false)
  dnaVersion           String                 @default("v1")
  source               String?
  mode                 String?
  triggeredBy          String?
  metadata             Json?
  tenantId             String?
  timezone             String                 @default("Asia/Kolkata")
  academicHistory      StudentAcademicYear[]      @relation("BranchHistory")
  academicRecords      AcademicRecord[]
  activityLogs         ActivityLog[]          @relation("BranchLogs")
  Address              Address[]
  attendancePolicies   AttendancePolicy[]
  BankDetail           BankDetail[]
  books                Book[]                 @relation("BranchBooks")
  school               School                 @relation(fields: [schoolId], references: [id])
  accounts             ChartOfAccount[]
  Class                Class[]
  collections          Collection[]
  Discount             Discount[]
  DiscountType         DiscountType[]
  enquiries            Enquiry[]              @relation("BranchEnquiries")
  examResults          ExamResult[]           @relation("BranchExamResults")
  examTypes            ExamType[]             @relation("BranchExamTypes")
  FamilyDetail         FamilyDetail[]
  FeeComponentMaster   FeeComponentMaster[]
  feeStructures        FeeStructure[]
  FeeTemplateComponent FeeTemplateComponent[]
  FinancialRecord      FinancialRecord[]
  libraryIssues        IssueReturn[]          @relation("BranchLibraryIssues")
  journalEntries       JournalEntry[]
  ledgerEntries        LedgerEntry[]
  libraryMembers       LibraryMember[]        @relation("BranchLibraryMembers")
  MedicalRecord        MedicalRecord[]
  notifications        Notification[]         @relation("BranchNotifications")
  payrollRuns          PayrollRun[]           @relation("BranchPayroll")
  PreviousSchool       PreviousSchool[]
  routes               Route[]                @relation("BranchRoutes")
  SalaryRevision       SalaryRevision[]
  salarySlips          SalarySlip[]           @relation("BranchSlips")
  Section              Section[]
  staff                Staff[]
  StaffAdvance         StaffAdvance[]
  StaffAsset           StaffAsset[]
  StaffAttendance      StaffAttendance[]
  StaffBank            StaffBank[]
  StaffKYC             StaffKYC[]
  StaffProfessional    StaffProfessional[]
  StaffStatutory       StaffStatutory[]
  students             Student[]              @relation("BranchStudents")
  StudentAttendance    StudentAttendance[]
  StudentFeeComponent  StudentFeeComponent[]
  subjects             Subject[]              @relation("BranchSubjects")
  TransportDetail      TransportDetail[]
  vehicles             Vehicle[]              @relation("BranchVehicles")
  vehicleStops         VehicleStop[]          @relation("BranchStops")
  sovereignRoles       SovereignRole[]
  drivers              Driver[]
  schoolCalendars      SchoolCalendar[]
  biometricDevices     BiometricDevice[]

  @@unique([schoolId, code])
}

model AcademicYear {
  id            String            @id @default(uuid())
  name          String
  startDate     DateTime
  endDate       DateTime
  isCurrent     Boolean           @default(false)
  isLocked      Boolean           @default(false)
  isGenesis     Boolean           @default(false)
  dnaVersion    String            @default("v1")
  source        String?
  mode          String?
  triggeredBy   String?
  metadata      Json?
  createdAt     DateTime          @default(now())
  schoolId      String
  history       StudentAcademicYear[]
  school        School            @relation(fields: [schoolId], references: [id])
  feeStructures FeeStructure[]
  ledgerEntries LedgerEntry[]
  consents      StudentConsent[]
  financialYearId String?
  financialYear   FinancialYear?    @relation(fields: [financialYearId], references: [id])
  promotions      PromotionBatch[]

  @@index([schoolId])
  @@index([financialYearId])
}

model FinancialYear {
  id               String         @id @default(uuid())
  name             String
  startDate        DateTime
  endDate          DateTime
  isCurrent        Boolean        @default(false)
  isLocked         Boolean        @default(false)
  isGenesis        Boolean        @default(false)
  dnaVersion       String         @default("v1")
  source           String?
  mode             String?
  triggeredBy      String?
  metadata         Json?
  schoolId         String
  backboneInvoices FeeInvoice[]
  school           School         @relation(fields: [schoolId], references: [id])
  journals         JournalEntry[]
  ledgerEntries    LedgerEntry[]
  academicYears    AcademicYear[]

  @@index([schoolId])
}

model Class {
  id              String              @id @default(uuid())
  name            String
  level           Int
  isGenesis       Boolean             @default(false)
  dnaVersion      String              @default("v1")
  source          String?
  mode            String?
  triggeredBy     String?
  schoolId        String
  branchId        String
  history         StudentAcademicYear[]
  academicRecords AcademicRecord[]
  branch          Branch              @relation(fields: [branchId], references: [id])
  school          School              @relation(fields: [schoolId], references: [id])
  feeStructures   FeeStructure[]
  sections        Section[]
  classTeacher    Staff?              @relation("ClassTeacher")
  attendance      StudentAttendance[]
  subjects        Subject[]
  homeworks       Homework[]

  @@index([branchId])
  @@index([schoolId])
}

model Section {
  id              String              @id @default(uuid())
  name            String
  classId         String
  capacity        Int                 @default(30)
  isGenesis       Boolean             @default(false)
  dnaVersion      String              @default("v1")
  source          String?
  mode            String?
  triggeredBy     String?
  schoolId        String
  branchId        String
  classTeacherId  String?             @unique
  history         StudentAcademicYear[]
  academicRecords AcademicRecord[]
  branch          Branch              @relation(fields: [branchId], references: [id])
  class           Class               @relation(fields: [classId], references: [id])
  classTeacher    Staff?              @relation("SectionTeacher", fields: [classTeacherId], references: [id])
  school          School              @relation(fields: [schoolId], references: [id])
  attendance      StudentAttendance[]
  homeworks       Homework[]

  @@index([branchId])
  @@index([classId])
  @@index([schoolId])
}

model Student {
  id               String                      @id @default(uuid())
  registrationId   String?                     @unique
  admissionNumber  String?
  studentCode      String?
  legacyId         String?                     @unique
  bookId           String?                     @unique
  firstName        String
  middleName       String?
  lastName         String?
  email            String?
  phone            String?
  dob              DateTime?
  gender           String?
  bloodGroup       String?
  category         String?
  aadhaarNumber    String?
  aadhaarVerified  Boolean                     @default(false)
  motherTongue     String?
  placeOfBirth     String?
  birthCertNo      String?
  usnSrnNumber     String?
  studentPhoto     String?
  minorityStatus   Boolean                     @default(false)
  bplStatus        Boolean                     @default(false)
  disabilityType   String?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  isDeleted        Boolean                     @default(false)
  deletedAt        DateTime?
  schoolId         String?
  branchId         String?
  status           String                      @default("Active")
  history          StudentAcademicYear[]
  academic         AcademicRecord?
  address          Address?
  bank             BankDetail?
  collections      Collection[]
  creditNotes      CreditNote[]
  documents        Document[]
  examResults      ExamResult[]
  family           FamilyDetail?
  backboneInvoices FeeInvoice[]
  financial        FinancialRecord?
  ledgerEntries    LedgerEntry[]
  libraryMember    LibraryMember?
  medical          MedicalRecord?
  previousSchool   PreviousSchool?
  branch           Branch?                     @relation("BranchStudents", fields: [branchId], references: [id])
  school           School?                     @relation(fields: [schoolId], references: [id])
  attendance       StudentAttendance[]
  consents         StudentConsent[]
  transportAssign  StudentTransportAssignment?
  newTransport     TransportAssignment?        @relation("NewTransport")
  transportHistory TransportCollection[]       @relation("TransportHistory")
  transport        TransportDetail?
  studentTransport StudentTransport?
  busAttendances   BusAttendance[]
  unlockRequests   UnlockRequest[]
  promotionRecords PromotionRecord[]
  guardians        StudentGuardian[]
  homeworkSubmissions HomeworkSubmission[]
  feedbacks        Feedback[]
  profileRequests  ProfileChangeRequest[]

  @@unique([schoolId, branchId, studentCode])
  @@unique([schoolId, branchId, admissionNumber])
  @@index([branchId])
  @@index([schoolId])
  @@index([studentCode])
  @@index([registrationId])
}

model StudentAcademicYear {
  id              String       @id
  studentId       String
  academicYearId  String
  classId         String
  sectionId       String?
  rollNumber      String?
  promotionStatus String
  renewalStatus   String       @default("PENDING") // "PENDING", "RENEWED", "CANCELLED"
  promotedFrom    String?
  admissionDate   DateTime?
  exitDate        DateTime?
  tcNumber        String?
  leavingReason   String?
  admissionNumber String?
  studentCode     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  isGenesis       Boolean      @default(false)
  role            Role         @default(STAFF)
  ownerScope      OwnerScope   @default(BRANCH_ONLY)
  schoolId        String?
  branchId        String?
  academicYear    AcademicYear @relation(fields: [academicYearId], references: [id])
  branch          Branch?      @relation("BranchHistory", fields: [branchId], references: [id])
  class           Class        @relation(fields: [classId], references: [id])
  school          School?      @relation(fields: [schoolId], references: [id])
  section         Section?     @relation(fields: [sectionId], references: [id])
  student         Student      @relation(fields: [studentId], references: [id])
  collections     Collection[]
  promotionBatchId String?
  promotionBatch   PromotionBatch? @relation(fields: [promotionBatchId], references: [id])

  @@unique([studentId, academicYearId])
  @@unique([schoolId, branchId, admissionNumber])
  @@index([branchId])

  @@index([academicYearId])
  @@index([classId])
  @@index([sectionId])
  @@index([promotionBatchId])
  @@map("AcademicHistory")
}

model AcademicRecord {
  id            String   @id @default(uuid())
  studentId     String   @unique
  admissionDate DateTime @default(now())
  academicYear  String
  classId       String?
  sectionId     String?
  branchId      String
  rollNumber    String?
  biometricId   String?
  penNumber     String?
  apaarId       String?
  samagraId     String?
  stsId         String?
  tcNumber      String?
  admissionType String?
  boardingType  String?
  group         String?
  subcategory   String?
  schoolId      String?
  branch        Branch   @relation(fields: [branchId], references: [id])
  class         Class?   @relation(fields: [classId], references: [id])
  school        School?  @relation(fields: [schoolId], references: [id])
  section       Section? @relation(fields: [sectionId], references: [id])
  student       Student  @relation(fields: [studentId], references: [id])

  @@index([branchId])
  @@index([classId])
  @@index([schoolId])
  @@index([sectionId])
  @@index([academicYear])
}

model FamilyDetail {
  id                  String  @id @default(uuid())
  studentId           String  @unique
  fatherName          String?
  fatherPhone         String?
  fatherAltPhone      String?
  fatherEmail         String?
  fatherOccupation    String?
  fatherQualification String?
  motherName          String?
  motherPhone         String?
  motherAltPhone      String?
  motherEmail         String?
  motherOccupation    String?
  motherQualification String?
  whatsappNumber      String?
  emergencyName       String?
  emergencyPhone      String?
  emergencyRelation   String?
  fatherAadhaar       String?
  motherAadhaar       String?
  schoolId            String?
  branchId            String?
  branch              Branch? @relation(fields: [branchId], references: [id])
  school              School? @relation(fields: [schoolId], references: [id])
  student             Student @relation(fields: [studentId], references: [id])

  @@index([fatherPhone])
  @@index([motherPhone])

  @@index([branchId])
  @@index([schoolId])
}

model Address {
  id               String  @id @default(uuid())
  studentId        String  @unique
  currentAddress   String?
  permanentAddress String?
  city             String?
  state            String?
  country          String? @default("India")
  pincode          String?
  schoolId         String?
  branchId         String?
  branch           Branch? @relation(fields: [branchId], references: [id])
  school           School? @relation(fields: [schoolId], references: [id])
  student          Student @relation(fields: [studentId], references: [id])

  @@index([permanentAddress])

  @@index([branchId])
  @@index([schoolId])
}

model TransportDetail {
  id                String   @id @default(uuid())
  studentId         String   @unique
  transportRequired Boolean  @default(false)
  route             String?
  pickupStop        String?
  dropStop          String?
  monthlyFee        Decimal? @db.Decimal(10, 2)
  schoolId          String?
  branchId          String?
  branch            Branch?  @relation(fields: [branchId], references: [id])
  school            School?  @relation(fields: [schoolId], references: [id])
  student           Student  @relation(fields: [studentId], references: [id])

  @@index([branchId])
  @@index([schoolId])
}

model MedicalRecord {
  id                String  @id @default(uuid())
  studentId         String  @unique
  medicalConditions String?
  allergies         String?
  doctorName        String?
  doctorPhone       String?
  schoolId          String?
  branchId          String?
  branch            Branch? @relation(fields: [branchId], references: [id])
  school            School? @relation(fields: [schoolId], references: [id])
  student           Student @relation(fields: [studentId], references: [id])

  @@index([branchId])
  @@index([schoolId])
}

model BankDetail {
  id            String  @id @default(uuid())
  studentId     String  @unique
  accountName   String?
  accountNumber String?
  ifscCode      String?
  bankBranch    String?
  schoolId      String?
  branchId      String?
  branch        Branch? @relation(fields: [branchId], references: [id])
  school        School? @relation(fields: [schoolId], references: [id])
  student       Student @relation(fields: [studentId], references: [id])

  @@index([branchId])
  @@index([schoolId])
}

model PreviousSchool {
  id               String    @id @default(uuid())
  studentId        String    @unique
  schoolName       String?
  previousClass    String?
  tcNumber         String?
  dateOfLeaving    DateTime?
  reasonForLeaving String?
  schoolId         String?
  branchId         String?
  branch           Branch?   @relation(fields: [branchId], references: [id])
  school           School?   @relation(fields: [schoolId], references: [id])
  student          Student   @relation(fields: [studentId], references: [id])

  @@index([branchId])
  @@index([schoolId])
}

model Document {
  id         String   @id @default(uuid())
  studentId  String?
  staffId    String?
  fileName   String
  fileType   String
  fileUrl    String
  uploadedAt DateTime @default(now())
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id])
  staff      Staff?   @relation(fields: [staffId], references: [id])
  student    Student? @relation(fields: [studentId], references: [id])

  @@index([schoolId])
  @@index([staffId])
  @@index([studentId])
}

model FinancialRecord {
  id               String                @id @default(uuid())
  studentId        String                @unique
  annualTuition    Decimal?              @db.Decimal(12, 2)
  totalDiscount    Decimal?              @default(0) @db.Decimal(12, 2)
  netTuition       Decimal?              @db.Decimal(12, 2)
  term1Amount      Decimal?              @db.Decimal(12, 2)
  term2Amount      Decimal?              @db.Decimal(12, 2)
  term3Amount      Decimal               @default(0) @db.Decimal(12, 2)
  admissionFee     Decimal?              @db.Decimal(12, 2)
  cautionDeposit   Decimal?              @db.Decimal(12, 2)
  computerFee      Decimal?              @db.Decimal(12, 2)
  developmentFee   Decimal?              @db.Decimal(12, 2)
  examFee          Decimal?              @db.Decimal(12, 2)
  feeScheduleId    String?
  labFee           Decimal?              @db.Decimal(12, 2)
  libraryFee       Decimal?              @db.Decimal(12, 2)
  miscellaneousFee Decimal?              @db.Decimal(12, 2)
  paymentType      String?
  sportsFee        Decimal?              @db.Decimal(12, 2)
  transportFee     Decimal?              @db.Decimal(12, 2)
  tuitionFee       Decimal?              @db.Decimal(12, 2)
  feeStructureId   String?
  schoolId         String?
  branchId         String?
  discounts        Discount[]
  branch           Branch?               @relation(fields: [branchId], references: [id])
  feeStructure     FeeStructure?         @relation(fields: [feeStructureId], references: [id])
  school           School?               @relation(fields: [schoolId], references: [id])
  student          Student               @relation(fields: [studentId], references: [id])
  components       StudentFeeComponent[]

  @@index([studentId])
  @@index([feeStructureId])
  @@index([schoolId])
  @@index([branchId])
}

model Discount {
  id                 String          @id @default(uuid())
  schoolId           String
  studentFinancialId String
  discountTypeId     String
  amount             Decimal         @db.Decimal(12, 2)
  status             String          @default("Pending")
  authorizerId       String?
  reason             String?
  branchId           String?
  authorizer         Staff?          @relation("DiscountAuthorizer", fields: [authorizerId], references: [id])
  branch             Branch?         @relation(fields: [branchId], references: [id])
  discountType       DiscountType    @relation(fields: [discountTypeId], references: [id])
  school             School          @relation(fields: [schoolId], references: [id])
  financialRecord    FinancialRecord @relation(fields: [studentFinancialId], references: [id])

  @@index([studentFinancialId])
  @@index([discountTypeId])
  @@index([schoolId])
  @@index([branchId])

  @@index([authorizerId])
}

model DiscountType {
  id          String     @id @default(uuid())
  name        String     @unique
  amount      Decimal?   @db.Decimal(12, 2)
  description String?
  percentage  Decimal?   @db.Decimal(5, 2)
  schoolId    String
  branchId    String?
  isActive    Boolean    @default(true)
  discounts   Discount[]
  branch      Branch?    @relation(fields: [branchId], references: [id])
  school      School     @relation(fields: [schoolId], references: [id])

  @@index([branchId])
  @@index([schoolId])
}

model FeeComponentMaster {
  id                   String                 @id @default(uuid())
  schoolId             String
  name                 String
  type                 String                 @default("ANCILLARY")
  isOneTime            Boolean                @default(false)
  isRefundable         Boolean                @default(false)
  accountCode          String?
  isGenesis            Boolean                @default(false)
  dnaVersion           String                 @default("v1")
  source               String?
  triggeredBy          String?
  branchId             String?
  amount               Decimal?               @db.Decimal(12, 2)
  description          String?
  isActive             Boolean                @default(true)
  branch               Branch?                @relation(fields: [branchId], references: [id])
  school               School                 @relation(fields: [schoolId], references: [id])
  backboneInvoiceItems FeeInvoiceItem[]
  templateLinks        FeeTemplateComponent[]
  studentComponents    StudentFeeComponent[]

  @@unique([schoolId, branchId, name])

  @@index([branchId])
}

model FeeStructure {
  id             String                 @id @default(uuid())
  structureCode  String?
  branchId       String
  classId        String?
  academicYearId String
  name           String
  schoolId       String
  totalAmount    Decimal                @db.Decimal(12, 2)
  isGenesis      Boolean                @default(false)
  dnaVersion     String                 @default("v1")
  source         String?
  mode           String?
  triggeredBy    String?
  description    String?
  isActive       Boolean                @default(true)
  academicYear   AcademicYear           @relation(fields: [academicYearId], references: [id])
  branch         Branch                 @relation(fields: [branchId], references: [id])
  class          Class?                 @relation(fields: [classId], references: [id])
  school         School                 @relation(fields: [schoolId], references: [id])
  components     FeeTemplateComponent[]
  students       FinancialRecord[]
  ledgerEntries  LedgerEntry[]

  @@unique([schoolId, structureCode])
  @@index([schoolId])

  @@index([academicYearId])
  @@index([branchId])
  @@index([classId])
}

model FeeTemplateComponent {
  id              String             @id @default(uuid())
  schoolId        String?
  branchId        String?
  templateId      String
  componentId     String
  amount          Decimal            @db.Decimal(12, 2)
  scheduleType    String             @default("ONE_TIME")
  branch          Branch?            @relation(fields: [branchId], references: [id])
  masterComponent FeeComponentMaster @relation(fields: [componentId], references: [id])
  school          School?            @relation(fields: [schoolId], references: [id])
  template        FeeStructure       @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([componentId])
  @@index([schoolId])
  @@index([branchId])
}

model StudentFeeComponent {
  id                 String             @id @default(uuid())
  schoolId           String?
  branchId           String?
  studentFinancialId String
  componentId        String
  baseAmount         Decimal            @db.Decimal(12, 2)
  waiverAmount       Decimal            @default(0) @db.Decimal(12, 2)
  discountAmount     Decimal            @default(0) @db.Decimal(12, 2)
  isApplicable       Boolean            @default(true)
  waiverReason       String?
  authorizerId       String?
  lastModifiedAt     DateTime           @updatedAt
  isLocked           Boolean            @default(false)
  lockReason         String?            @default("ADMISSION")
  lockedAt           DateTime?
  version            Int                @default(1)
  authorizer         Staff?             @relation(fields: [authorizerId], references: [id])
  branch             Branch?            @relation(fields: [branchId], references: [id])
  masterComponent    FeeComponentMaster @relation(fields: [componentId], references: [id])
  school             School?            @relation(fields: [schoolId], references: [id])
  financialRecord    FinancialRecord    @relation(fields: [studentFinancialId], references: [id])

  @@index([studentFinancialId])
  @@index([schoolId])
  @@index([branchId])

  @@index([authorizerId])
  @@index([componentId])
}

model LedgerEntry {
  id              String         @id @default(uuid())
  studentId       String
  schoolId        String
  branchId        String?
  type            String
  amount          Decimal        @db.Decimal(12, 2)
  reason          String
  createdBy       String
  createdAt       DateTime       @default(now())
  academicYearId  String?
  financialYearId String?
  journalEntryId  String?
  feeStructureId  String?
  academicYear    AcademicYear?  @relation(fields: [academicYearId], references: [id])
  branch          Branch?        @relation(fields: [branchId], references: [id])
  feeStructure    FeeStructure?  @relation(fields: [feeStructureId], references: [id])
  financialYear   FinancialYear? @relation(fields: [financialYearId], references: [id])
  journalEntry    JournalEntry?  @relation(fields: [journalEntryId], references: [id])
  school          School         @relation(fields: [schoolId], references: [id])
  student         Student        @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([schoolId])
  @@index([branchId])

  @@index([academicYearId])
  @@index([feeStructureId])
  @@index([financialYearId])
  @@index([journalEntryId])
}

model FeeInvoice {
  id              String                 @id @default(uuid())
  invoiceNumber   String?                @unique
  studentId       String
  academicYearId  String
  financialYearId String
  totalAmount     Decimal                @db.Decimal(12, 2)
  paidAmount      Decimal                @default(0) @db.Decimal(12, 2)
  balance         Decimal                @db.Decimal(12, 2)
  dueDate         DateTime
  status          String                 @default("PENDING")
  isLocked        Boolean                @default(false)
  generatedAt     DateTime               @default(now())
  schoolId        String
  branchId        String
  allocations     CollectionAllocation[]
  financialYear   FinancialYear          @relation(fields: [financialYearId], references: [id])
  school          School                 @relation(fields: [schoolId], references: [id])
  student         Student                @relation(fields: [studentId], references: [id])
  items           FeeInvoiceItem[]

  @@index([studentId])
  @@index([schoolId])

  @@index([financialYearId])
}

model FeeInvoiceItem {
  id              String                 @id @default(uuid())
  invoiceId       String
  componentId     String?
  componentName   String
  componentType   String                 @default("TUTION")
  amount          Decimal                @db.Decimal(12, 2)
  paidAmount      Decimal                @default(0) @db.Decimal(12, 2)
  balance         Decimal                @db.Decimal(12, 2)
  priority        Int                    @default(100)
  ledgerCode      String?
  allocations     CollectionAllocation[]
  masterComponent FeeComponentMaster?    @relation(fields: [componentId], references: [id])
  invoice         FeeInvoice             @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])

  @@index([componentId])
}

model CollectionAllocation {
  id            String         @id @default(uuid())
  collectionId  String
  invoiceId     String
  invoiceItemId String
  amount        Decimal        @db.Decimal(12, 2)
  createdAt     DateTime       @default(now())
  collection    Collection     @relation(fields: [collectionId], references: [id])
  invoice       FeeInvoice     @relation(fields: [invoiceId], references: [id])
  invoiceItem   FeeInvoiceItem @relation(fields: [invoiceItemId], references: [id])

  @@index([collectionId])
  @@index([invoiceId])
  @@index([invoiceItemId])
}

model AllocationPriority {
  id            String @id @default(uuid())
  schoolId      String
  componentType String
  priority      Int

  @@unique([schoolId, componentType])
}

model LateFeeRule {
  id            String   @id @default(uuid())
  schoolId      String
  componentType String   @default("TUTION")
  graceDays     Int      @default(5)
  type          String   @default("FIXED")
  value         Decimal  @db.Decimal(12, 2)
  maxCap        Decimal? @db.Decimal(12, 2)

  @@unique([schoolId, componentType])
}

model FinancialPeriod {
  id       String    @id @default(uuid())
  schoolId String
  year     String
  isLocked Boolean   @default(false)
  lockedAt DateTime?
  lockedBy String?

  @@unique([schoolId, year])
}

model Collection {
  id                  String                 @id @default(uuid())
  receiptNumber       String
  bookReceiptNo       String?
  studentId           String
  admissionId         String?
  financialYearId     String
  schoolId            String
  branchId            String
  amountPaid          Decimal                @db.Decimal(12, 2)
  lateFeePaid         Decimal                @default(0) @db.Decimal(12, 2)
  convenienceFee      Decimal?               @db.Decimal(12, 2)
  totalPaid           Decimal                @db.Decimal(12, 2)
  paymentMode         String
  paymentReference    String?
  allocatedTo         Json?
  paymentDate         DateTime               @default(now())
  collectedBy         String
  journalEntryId      String?                @unique
  isAutomated         Boolean                @default(false)
  status              String                 @default("Success")
  isDeleted           Boolean                @default(false)
  deletedAt           DateTime?
  admission           StudentAcademicYear?       @relation(fields: [admissionId], references: [id])
  branch              Branch                 @relation(fields: [branchId], references: [id])
  journalEntry        JournalEntry?          @relation(fields: [journalEntryId], references: [id])
  school              School                 @relation(fields: [schoolId], references: [id])
  student             Student                @relation(fields: [studentId], references: [id])
  backboneAllocations CollectionAllocation[]

  @@unique([schoolId, receiptNumber])
  @@index([schoolId])
  @@index([receiptNumber])
  @@index([admissionId])
  @@index([studentId])

  @@index([branchId])
}

model ChartOfAccount {
  id             String        @id @default(uuid())
  accountCode    String
  accountName    String
  accountType    String
  currentBalance Decimal       @default(0) @db.Decimal(15, 2)
  schoolId       String
  branchId       String?
  branch         Branch?       @relation(fields: [branchId], references: [id])
  school         School        @relation(fields: [schoolId], references: [id])
  journals       JournalLine[]

  @@unique([schoolId, accountCode])

  @@index([branchId])
}

model JournalEntry {
  id              String        @id @default(uuid())
  entryCode       String?
  financialYearId String
  entryDate       DateTime      @default(now())
  entryType       String
  description     String?
  totalDebit      Decimal       @db.Decimal(15, 2)
  totalCredit     Decimal       @db.Decimal(15, 2)
  schoolId        String
  branchId        String?
  collection      Collection?
  expense         Expense?
  branch          Branch?       @relation(fields: [branchId], references: [id])
  financialYear   FinancialYear @relation(fields: [financialYearId], references: [id])
  school          School        @relation(fields: [schoolId], references: [id])
  lines           JournalLine[]
  ledgerEntries   LedgerEntry[]

  @@unique([schoolId, branchId, entryCode])
  @@index([schoolId])
  @@index([branchId])

  @@index([financialYearId])
}

model JournalLine {
  id             String         @id @default(uuid())
  journalEntryId String
  description    String?
  accountId      String
  credit         Decimal        @default(0) @db.Decimal(15, 2)
  debit          Decimal        @default(0) @db.Decimal(15, 2)
  account        ChartOfAccount @relation(fields: [accountId], references: [id])
  journalEntry   JournalEntry   @relation(fields: [journalEntryId], references: [id])

  @@index([accountId])
  @@index([journalEntryId])
}

model Expense {
  id               String          @id @default(uuid())
  category         String
  amount           Decimal         @db.Decimal(12, 2)
  description      String?
  journalEntryId   String?         @unique
  paymentRequestId String?         @unique
  journalEntry     JournalEntry?   @relation(fields: [journalEntryId], references: [id])
  paymentRequest   PaymentRequest? @relation(fields: [paymentRequestId], references: [id])
}

model PaymentRequest {
  id            String            @id
  amount        Decimal           @db.Decimal(12, 2)
  status        String            @default("Pending")
  approvalLevel String
  requesterId   String
  expense       Expense?
  approvals     PaymentApproval[]
  execution     PaymentExecution?
}

model PaymentApproval {
  id               String         @id @default(uuid())
  paymentRequestId String
  approverId       String
  status           String
  comments         String?
  createdAt        DateTime       @default(now())
  paymentRequest   PaymentRequest @relation(fields: [paymentRequestId], references: [id])

  @@index([paymentRequestId])
}

model PaymentExecution {
  id               String         @id @default(uuid())
  paymentRequestId String         @unique
  voucherNumber    String         @unique
  paymentMode      String
  reference        String?
  executedAt       DateTime       @default(now())
  isDeleted        Boolean        @default(false)
  deletedAt        DateTime?
  paymentRequest   PaymentRequest @relation(fields: [paymentRequestId], references: [id])
}

model Staff {
  id                  String                @id @default(uuid())
  staffCode           String
  firstName           String
  middleName          String?
  lastName            String
  email               String?
  phone               String?
  dob                 DateTime?
  gender              String?
  branchId            String
  schoolId            String
  photoUrl            String?
  status              String                @default("Active")
  userId              String?
  role                String                @default("STAFF")
  address             String?
  onboardingStatus    String?               @default("JOINED")
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  passwordHash        String?
  username            String?               @unique
  assignedClassId     String?               @unique
  departmentId        String?
  categoryId          String?
  attendancePolicyId  String?
  biometricId         String?               @unique
  mobilePasswordUsed  Boolean               @default(false)
  mobileSessionToken  String?
  /// FK to the branch-scoped or school-wide role definition
  sovereignRoleId     String?
  exceptions          AttendanceException[]
  Discount            Discount[]            @relation("DiscountAuthorizer")
  documents           Document[]
  leaveRequests       LeaveRequest[]
  approvalRequests    ApprovalRequest[]     @relation("StaffRequests")
  salarySlips         SalarySlip[]
  assignedSection     Section?              @relation("SectionTeacher")
  assignedClass       Class?                @relation("ClassTeacher", fields: [assignedClassId], references: [id])
  attendancePolicy    AttendancePolicy?     @relation(fields: [attendancePolicyId], references: [id])
  branch              Branch                @relation(fields: [branchId], references: [id])
  category            StaffCategory?        @relation(fields: [categoryId], references: [id])
  department          StaffDepartment?      @relation(fields: [departmentId], references: [id])
  school              School                @relation(fields: [schoolId], references: [id])
  sovereignRole       SovereignRole?        @relation("StaffSovereignRole", fields: [sovereignRoleId], references: [id])
  advances            StaffAdvance[]
  attendance          StaffAttendance[]
  bank                StaffBank?
  faceProfile         StaffFaceProfile?
  professional        StaffProfessional?
  statutory           StaffStatutory?
  StudentFeeComponent StudentFeeComponent[]
  vehicleAssignments  VehicleStaff[]
  employeeCategory    EmployeeCategory?
  employmentType      EmploymentType?
  identityVersion     String            @default("V1")
  bloodGroup          String?
  allergies           String?
  emergencyName       String?
  emergencyPhone      String?
  staffDocuments      StaffDocument[]
  promotions          PromotionBatch[]

  @@unique([branchId, staffCode])
  @@unique([branchId, email])
  @@unique([branchId, phone])
  @@unique([branchId, userId])
  @@index([schoolId])

  @@index([attendancePolicyId])
  @@index([categoryId])
  @@index([departmentId])
  @@index([sovereignRoleId])
}

model StaffProfessional {
  id                 String   @id @default(uuid())
  staffId            String   @unique
  designation        String
  department         String?
  qualification      String?
  experienceYears    Float?
  dateOfJoining      DateTime
  basicSalary        Decimal  @db.Decimal(12, 2)
  daAmount           Decimal  @default(0) @db.Decimal(12, 2)
  isDAEnabled        Boolean  @default(false)
  isESIEnabled       Boolean  @default(false)
  isPFEnabled        Boolean  @default(false)
  hraAmount          Decimal  @default(0) @db.Decimal(12, 2)
  isPTEnabled        Boolean  @default(false)
  specialAllowance   Decimal  @default(0) @db.Decimal(12, 2)
  transportAllowance Decimal  @default(0) @db.Decimal(12, 2)
  casualLeaveBalance Int      @default(0)
  sickLeaveBalance   Int      @default(0)
  schoolId           String?
  branchId           String?
  branch             Branch?  @relation(fields: [branchId], references: [id])
  school             School?  @relation(fields: [schoolId], references: [id])
  staff              Staff    @relation(fields: [staffId], references: [id])

  @@index([branchId])
  @@index([schoolId])
}

model StaffAdvance {
  id            String   @id @default(uuid())
  staffId       String
  amount        Decimal  @db.Decimal(12, 2)
  balance       Decimal  @db.Decimal(12, 2)
  installment   Decimal  @db.Decimal(12, 2)
  disbursedDate DateTime @default(now())
  status        String   @default("Active")
  reason        String?
  schoolId      String?
  branchId      String?
  branch        Branch?  @relation(fields: [branchId], references: [id])
  school        School?  @relation(fields: [schoolId], references: [id])
  staff         Staff    @relation(fields: [staffId], references: [id])

  @@index([branchId])
  @@index([schoolId])
  @@index([staffId])
}

model StaffStatutory {
  id            String  @id @default(uuid())
  staffId       String  @unique
  panNumber     String? @unique
  pfNumber      String? @unique
  uanNumber     String? @unique
  esiNumber     String? @unique
  aadhaarNumber String?
  schoolId      String?
  branchId      String?
  branch        Branch? @relation(fields: [branchId], references: [id])
  school        School? @relation(fields: [schoolId], references: [id])
  staff         Staff   @relation(fields: [staffId], references: [id])

  @@index([branchId])
  @@index([schoolId])
}

model StaffBank {
  id            String  @id @default(uuid())
  staffId       String  @unique
  accountName   String
  accountNumber String
  ifscCode      String
  bankName      String
  schoolId      String?
  branchId      String?
  branch        Branch? @relation(fields: [branchId], references: [id])
  school        School? @relation(fields: [schoolId], references: [id])
  staff         Staff   @relation(fields: [staffId], references: [id])

  @@index([branchId])
  @@index([schoolId])
}

model StaffAttendance {
  id             String    @id @default(uuid())
  staffId        String
  date           DateTime
  status         String
  checkIn        DateTime?
  checkOut       DateTime?
  schoolId       String?
  branchId       String?
  isFaceVerified Boolean?  @default(false)
  lateMinutes    Int?      @default(0)
  isOverridden   Boolean?  @default(false)
  overriddenAt   DateTime?
  overriddenBy   String?
  remarks        String?
  branch         Branch?   @relation(fields: [branchId], references: [id])
  school         School?   @relation(fields: [schoolId], references: [id])
  staff          Staff     @relation(fields: [staffId], references: [id])

  @@unique([staffId, date])
  @@index([schoolId, date])

  @@index([branchId])
}

model StaffDocument {
  id               String   @id @default(uuid())
  staffId          String
  documentType     String
  customName       String?
  originalFileName String
  storedFileName   String
  fileUrl          String
  fileSize         Int
  fileExtension    String
  mimeType         String
  uploadedDate     DateTime @default(now())
  lastUpdatedDate  DateTime @updatedAt
  schoolId         String
  school           School   @relation(fields: [schoolId], references: [id])
  staff            Staff    @relation(fields: [staffId], references: [id])

  @@index([staffId])
  @@index([schoolId])
}

model StudentAttendance {
  id        String    @id @default(uuid())
  studentId String
  date      DateTime  @default(now())
  status    String    @default("Present")
  remarks   String?
  schoolId  String
  classId   String?
  entryTime DateTime?
  sectionId String?
  session   String    @default("Morning")
  branchId  String?
  branch    Branch?   @relation(fields: [branchId], references: [id])
  class     Class?    @relation(fields: [classId], references: [id])
  school    School    @relation(fields: [schoolId], references: [id])
  section   Section?  @relation(fields: [sectionId], references: [id])
  student   Student   @relation(fields: [studentId], references: [id])

  @@unique([studentId, date, session])
  @@index([studentId])
  @@index([date])
  @@index([branchId])

  @@index([classId])
  @@index([schoolId])
  @@index([sectionId])
}

model Route {
  id                 String                       @id @default(uuid())
  routeName          String
  routeCode          String                       @unique
  schoolId           String
  branchId           String?
  isDeleted          Boolean                      @default(false)
  deletedAt          DateTime?
  branch             Branch?                      @relation("BranchRoutes", fields: [branchId], references: [id])
  school             School                       @relation(fields: [schoolId], references: [id])
  assignments        StudentTransportAssignment[]
  vehicles           Vehicle[]
  stops              VehicleStop[]
  
  // V2 Relations
  studentTransports  StudentTransport[]
  driverAssignments  DriverAssignment[]
  tripSessions       TripSession[]
  polyline           RoutePolyline?
  enquiries          Enquiry[]                    @relation("EnquiryRoute")
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt

  @@index([branchId])
  @@index([schoolId])
}

model Vehicle {
  id                String             @id @default(uuid())
  registrationNo    String             @unique
  model             String?
  capacity          Int
  onboardingStatus  String?
  routeId           String
  branchId          String
  schoolId          String
  isDeleted         Boolean            @default(false)
  deletedAt         DateTime?
  branch            Branch             @relation("BranchVehicles", fields: [branchId], references: [id])
  route             Route              @relation(fields: [routeId], references: [id])
  staff             VehicleStaff[]
  
  // V2 Relations
  driverAssignments DriverAssignment[]
  tripSessions      TripSession[]
  incidents         VehicleIncident[]
  maintenances      VehicleMaintenance[]
  gpsLive           VehicleGPSLive?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  documents         Json?              // RC, insurance, pollution certificates, etc.

  @@index([branchId])
  @@index([schoolId])
}

model VehicleStop {
  id                String                       @id @default(uuid())
  routeId           String
  stopName          String
  pickupTime        String?
  dropTime          String?
  monthlyFee        Decimal                      @db.Decimal(10, 2)
  branchId          String?
  schoolId          String?
  isDeleted         Boolean                      @default(false)
  deletedAt         DateTime?
  dropAssignments   StudentTransportAssignment[] @relation("DropStop")
  pickupAssignments StudentTransportAssignment[] @relation("PickupStop")
  branch            Branch?                      @relation("BranchStops", fields: [branchId], references: [id])
  route             Route                        @relation(fields: [routeId], references: [id])
  school            School?                      @relation(fields: [schoolId], references: [id])
  
  // V2 Relations
  pickupTransports  StudentTransport[]           @relation("PickupStopV2")
  dropTransports    StudentTransport[]           @relation("DropStopV2")
  enquiries         Enquiry[]                    @relation("EnquiryStop")
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt

  @@index([branchId])
  @@index([schoolId])

  @@index([routeId])
}

model VehicleStaff {
  id        String  @id @default(uuid())
  vehicleId String
  staffId   String
  role      String
  staff     Staff   @relation(fields: [staffId], references: [id])
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([staffId])
  @@index([vehicleId])
}

model StudentTransportAssignment {
  id           String      @id @default(uuid())
  studentId    String      @unique
  dropStopId   String
  monthlyFee   Decimal     @db.Decimal(10, 2)
  pickupStopId String
  routeId      String
  schoolId     String
  status       String      @default("Active")
  dropStop     VehicleStop @relation("DropStop", fields: [dropStopId], references: [id])
  pickupStop   VehicleStop @relation("PickupStop", fields: [pickupStopId], references: [id])
  route        Route       @relation(fields: [routeId], references: [id])
  school       School      @relation(fields: [schoolId], references: [id])
  student      Student     @relation(fields: [studentId], references: [id])

  @@index([dropStopId])
  @@index([pickupStopId])
  @@index([routeId])
  @@index([schoolId])
}

model Subject {
  id          String       @id @default(uuid())
  name        String
  code        String       @unique
  classId     String?
  schoolId    String
  branchId    String?
  examResults ExamResult[]
  branch      Branch?      @relation("BranchSubjects", fields: [branchId], references: [id])
  class       Class?       @relation(fields: [classId], references: [id])
  school      School       @relation(fields: [schoolId], references: [id])

  @@index([branchId])

  @@index([classId])
  @@index([schoolId])
}

model ExamType {
  id           String       @id @default(uuid())
  name         String
  academicYear String
  schoolId     String
  branchId     String?
  results      ExamResult[]
  branch       Branch?      @relation("BranchExamTypes", fields: [branchId], references: [id])
  school       School       @relation(fields: [schoolId], references: [id])

  @@index([branchId])

  @@index([schoolId])
}

model GradeScale {
  id       String @id @default(uuid())
  grade    String
  minScore Int
  maxScore Int
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
}

model ExamResult {
  id            String   @id @default(uuid())
  studentId     String
  examTypeId    String
  subjectId     String
  marksObtained Decimal  @db.Decimal(5, 2)
  totalMarks    Decimal  @db.Decimal(5, 2)
  remarks       String?
  schoolId      String
  passMarks     Decimal  @default(33) @db.Decimal(5, 2)
  branchId      String?
  branch        Branch?  @relation("BranchExamResults", fields: [branchId], references: [id])
  examType      ExamType @relation(fields: [examTypeId], references: [id])
  school        School   @relation(fields: [schoolId], references: [id])
  student       Student  @relation(fields: [studentId], references: [id])
  subject       Subject  @relation(fields: [subjectId], references: [id])

  @@index([branchId])
  @@index([schoolId, studentId, examTypeId])

  @@index([examTypeId])
  @@index([studentId])
  @@index([subjectId])
}

model Book {
  id          String        @id @default(uuid())
  accessionId String        @unique
  title       String
  author      String?
  isbn        String?
  category    String?
  status      String        @default("Available")
  branchId    String?
  branch      Branch?       @relation("BranchBooks", fields: [branchId], references: [id])
  issues      IssueReturn[]

  @@index([branchId])
}

model LibraryMember {
  id           String        @id @default(uuid())
  studentId    String        @unique
  membershipId String        @unique
  branchId     String?
  issues       IssueReturn[]
  branch       Branch?       @relation("BranchLibraryMembers", fields: [branchId], references: [id])
  student      Student       @relation(fields: [studentId], references: [id])

  @@index([branchId])
}

model IssueReturn {
  id         String        @id @default(uuid())
  bookId     String
  memberId   String
  issueDate  DateTime      @default(now())
  dueDate    DateTime
  returnDate DateTime?
  status     String        @default("Issued")
  branchId   String?
  book       Book          @relation(fields: [bookId], references: [id])
  branch     Branch?       @relation("BranchLibraryIssues", fields: [branchId], references: [id])
  member     LibraryMember @relation(fields: [memberId], references: [id])

  @@index([branchId])

  @@index([bookId])
  @@index([memberId])
}

model BiometricTemplate {
  id           String @id @default(uuid())
  personId     String @unique
  templateData String
  personType   String
}

model Notification {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  message   String
  recipient String
  schoolId  String
  status    String   @default("Pending")
  type      String
  branchId  String?
  branch    Branch?  @relation("BranchNotifications", fields: [branchId], references: [id])
  school    School   @relation(fields: [schoolId], references: [id])

  @@index([branchId])

