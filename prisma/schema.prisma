  isActive   Boolean   @default(true)
  lastPingAt DateTime?
  createdAt  DateTime  @default(now())
  school     School    @relation(fields: [schoolId], references: [id])
  branch     Branch    @relation(fields: [branchId], references: [id])

  @@index([schoolId, branchId])
}

