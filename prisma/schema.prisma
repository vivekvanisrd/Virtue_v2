  issuedAt  DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?
  schoolId  String
  branchId  String?
  driver    Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  school    School    @relation(fields: [schoolId], references: [id])

  @@index([driverId])
  @@index([tokenId])
  @@index([schoolId])
}

model CommunicationLog {
  id           String   @id @default(uuid())
  schoolId     String
  branchId     String?
  sender       String   // e.g. "office@virtueschool.in" or admin ID
  authorEmail  String?
  authorId     String?
  recipientId  String?
  recipient    String   // Parent/Staff email
  subject      String
  body         String   @db.Text
  type         String   // "RECEIPT" | "REMINDER" | "ADMISSION" | "PROMOTION" | "DEPARTURE" | "CUSTOM"
  status       String   // "SUCCESS" | "FAILED"
  errorMessage String?  @db.Text
  createdAt    DateTime @default(now())
  isRead       Boolean  @default(false)
  readAt       DateTime?
  parentId     String?

  @@index([schoolId])
  @@index([branchId])
}

model ApprovalRequest {
  id             String    @id @default(uuid())
  schoolId       String
  branchId       String?
  staffId        String
  category       String    // "LEAVE" | "ADVANCE" | "SUPPLIES" | "CUSTOM"
  title          String
  description    String    @db.Text
  startDate      DateTime? // Optional: for leaves
  endDate        DateTime? // Optional: for leaves
  amount         Decimal?  // Optional: for salary advances
  status         String    @default("PENDING") // "PENDING" | "APPROVED" | "REJECTED"
  reviewerId     String?   // Staff ID of the reviewer
  reviewerName   String?   // Name of the reviewer
  reviewComments String?   @db.Text
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  staff          Staff     @relation("StaffRequests", fields: [staffId], references: [id])
  school         School    @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([branchId])

  @@index([staffId])
}

enum SimulationStatus {
  RUNNING
  PAUSED
  STOPPED
  COMPLETED
}

enum NotificationDeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

model TransportSettings {
  id                   String   @id @default(uuid())
  schoolId             String   @unique
  approachRadius       Int      @default(1000)
  gpsInterval          Int      @default(5)
  gpsAccuracyThreshold Float    @default(100.0)
  maxSpeedLimit        Float    @default(150.0)
