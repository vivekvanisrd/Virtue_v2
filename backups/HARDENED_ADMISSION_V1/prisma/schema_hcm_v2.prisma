generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id                   String                       @id
  name                 String
  code                 String                       @unique
  address              String?
  phone                String?
  email                String?
  logo                 String?
  highestClass         String?
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt
  status               String                       @default("Active")
  academicHist         AcademicHistory[]
  academicRecs         AcademicRecord[]
  academicYears        AcademicYear[]
  activityLogs         ActivityLog[]
  branches             Branch[]
  accounts             ChartOfAccount[]
  collections          Collection[]
  discounts            Discount[]
  discountTypes        DiscountType[]
  docRecords           Document[]
  enquiries            Enquiry[]
  examResults          ExamResult[]
  examTypes            ExamType[]
  feeStructures        FeeStructure[]
  finRecords           FinancialRecord[]
  financialYears       FinancialYear[]
  gradeScales          GradeScale[]
  journals             JournalEntry[]
  notifications        Notification[]
  payrollRuns         PayrollRun[]
  routes               Route[]
  staff                Staff[]
  students             Student[]
  attendance           StudentAttendance[]
  transportAssignments StudentTransportAssignment[]
  subjects             Subject[]
  counters             TenancyCounter[]
}

model Branch {
  id              String           @id
  schoolId        String
  name            String
  code            String
  address         String?
  phone           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  academicRecords AcademicRecord[]
  school          School           @relation(fields: [schoolId], references: [id])
  accounts        ChartOfAccount[]
  collections     Collection[]
  feeStructures   FeeStructure[]
  staff           Staff[]
  routes          Route[]           @relation("BranchRoutes")
  vehicles        Vehicle[]         @relation("BranchVehicles")
  vehicleStops    VehicleStop[]     @relation("BranchStops")
  subjects        Subject[]         @relation("BranchSubjects")
  examTypes       ExamType[]        @relation("BranchExamTypes")
  examResults     ExamResult[]      @relation("BranchExamResults")
  books           Book[]            @relation("BranchBooks")
  libraryMembers  LibraryMember[]   @relation("BranchLibraryMembers")
  libraryIssues   IssueReturn[]     @relation("BranchLibraryIssues")
  notifications   Notification[]    @relation("BranchNotifications")
  enquiries       Enquiry[]         @relation("BranchEnquiries")
  academicHistory AcademicHistory[] @relation("BranchHistory")
  payrollRuns     PayrollRun[]      @relation("BranchPayroll")
  salarySlips     SalarySlip[]      @relation("BranchSlips")
  activityLogs    ActivityLog[]     @relation("BranchLogs")
  students        Student[]         @relation("BranchStudents")

  @@unique([schoolId, code])
}

model AcademicYear {
  id            String            @id
  name          String
  startDate     DateTime
  endDate       DateTime
  isCurrent     Boolean           @default(false)
  createdAt     DateTime          @default(now())
  schoolId      String
  history       AcademicHistory[]
  school        School            @relation(fields: [schoolId], references: [id])
  feeStructures FeeStructure[]
  consents      StudentConsent[]
}

model FinancialYear {
  id        String         @id
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean        @default(false)
  schoolId  String
  school    School         @relation(fields: [schoolId], references: [id])
  journals  JournalEntry[]
}

model Class {
  id              String              @id
  name            String
  level           Int
  history         AcademicHistory[]
  academicRecords AcademicRecord[]
  feeStructures   FeeStructure[]
  sections        Section[]
  attendance      StudentAttendance[]
  subjects        Subject[]
  classTeacher    Staff?              @relation("ClassTeacher")
}

model Section {
  id              String              @id
  name            String
  classId         String
  history         AcademicHistory[]
  academicRecords AcademicRecord[]
  class           Class               @relation(fields: [classId], references: [id])
  attendance      StudentAttendance[]
}

model Student {
  id              String                      @id @default(uuid())
  registrationId   String?                     @unique
  admissionNumber  String?
  studentCode      String?
  firstName        String
  middleName       String?
  lastName         String?
  email            String?
  phone            String?
  dob              DateTime?
  gender           String?
  bloodGroup       String?
  category         String?
  aadhaarNumber    String?
  aadhaarVerified  Boolean                     @default(false)
  motherTongue     String?
  placeOfBirth     String?
  birthCertNo      String?
  usnSrnNumber     String?
  studentPhoto     String?
  minorityStatus   Boolean                     @default(false)
  bplStatus        Boolean                     @default(false)
  disabilityType   String?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  schoolId         String
  branchId         String?
  status           String                      @default("Active")
  branch           Branch?                     @relation("BranchStudents", fields: [branchId], references: [id])
  history          AcademicHistory[]
  academic         AcademicRecord?
  address          Address?
  bank             BankDetail?
  collections      Collection[]
  documents        Document[]
  examResults      ExamResult[]
  family           FamilyDetail?
  financial        FinancialRecord?
  libraryMember    LibraryMember?
  medical          MedicalRecord?
  previousSchool   PreviousSchool?
  school           School                      @relation(fields: [schoolId], references: [id])
  attendance       StudentAttendance[]
  consents         StudentConsent[]
  transportAssign  StudentTransportAssignment?
  transport        TransportDetail?

  @@unique([schoolId, branchId, studentCode])
  @@unique([schoolId, branchId, admissionNumber])
  @@index([branchId])
  @@index([schoolId])
  @@index([studentCode])
  @@index([registrationId])
}

model AcademicHistory {
  id              String       @id
  studentId       String
  academicYearId  String
  classId         String
  sectionId       String?
  rollNumber      String?
  promotionStatus String
  promotedFrom    String?
  admissionDate   DateTime?
  exitDate        DateTime?
  tcNumber        String?
  leavingReason   String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  schoolId        String
  branchId        String?
  academicYear    AcademicYear @relation(fields: [academicYearId], references: [id])
  branch          Branch?      @relation("BranchHistory", fields: [branchId], references: [id])
  class           Class        @relation(fields: [classId], references: [id])
  school          School       @relation(fields: [schoolId], references: [id])
  section         Section?     @relation(fields: [sectionId], references: [id])
  student         Student      @relation(fields: [studentId], references: [id])

  @@unique([studentId, academicYearId])
  @@index([branchId])
}

model AcademicRecord {
  id            String   @id @default(uuid())
  studentId     String   @unique
  admissionDate DateTime @default(now())
  academicYear  String
  classId       String?
  sectionId     String?
  branchId      String
  rollNumber    String?
  biometricId   String?
  penNumber     String?
  apaarId       String?
  samagraId     String?
  stsId         String?
  tcNumber      String?
  admissionType String?
  boardingType  String?
  group         String?
  subcategory   String?
  schoolId      String
  branch        Branch   @relation(fields: [branchId], references: [id])
  class         Class?   @relation(fields: [classId], references: [id])
  school        School   @relation(fields: [schoolId], references: [id])
  section       Section? @relation(fields: [sectionId], references: [id])
  student       Student  @relation(fields: [studentId], references: [id])
}

model FamilyDetail {
  id                  String  @id @default(uuid())
  studentId           String  @unique
  fatherName          String?
  fatherPhone         String?
  fatherAltPhone      String?
  fatherEmail         String?
  fatherOccupation    String?
  fatherQualification String?
  motherName          String?
  motherPhone         String?
  motherAltPhone      String?
  motherEmail         String?
  motherOccupation    String?
  motherQualification String?
  whatsappNumber      String?
  emergencyName       String?
  emergencyPhone      String?
  emergencyRelation   String?
  fatherAadhaar       String?
  motherAadhaar       String?
  student             Student @relation(fields: [studentId], references: [id])
}

model Address {
  id               String  @id @default(uuid())
  studentId        String  @unique
  currentAddress   String?
  permanentAddress String?
  city             String?
  state            String?
  country          String? @default("India")
  pincode          String?
  student          Student @relation(fields: [studentId], references: [id])
}

model TransportDetail {
  id                String   @id @default(uuid())
  studentId         String   @unique
  transportRequired Boolean  @default(false)
  route             String?
  pickupStop        String?
  dropStop          String?
  monthlyFee        Decimal? @db.Decimal(10, 2)
  student           Student  @relation(fields: [studentId], references: [id])
}

model MedicalRecord {
  id                String  @id @default(uuid())
  studentId         String  @unique
  medicalConditions String?
  allergies         String?
  doctorName        String?
  doctorPhone       String?
  student           Student @relation(fields: [studentId], references: [id])
}

model BankDetail {
  id            String  @id @default(uuid())
  studentId     String  @unique
  accountName   String?
  accountNumber String?
  ifscCode      String?
  bankBranch    String?
  student       Student @relation(fields: [studentId], references: [id])
}

model PreviousSchool {
  id               String    @id @default(uuid())
  studentId        String    @unique
  schoolName       String?
  previousClass    String?
  tcNumber         String?
  dateOfLeaving    DateTime?
  reasonForLeaving String?
  student          Student   @relation(fields: [studentId], references: [id])
}

model Document {
  id         String   @id @default(uuid())
  studentId  String?
  staffId    String?
  fileName   String
  fileType   String
  fileUrl    String
  uploadedAt DateTime @default(now())
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id])
  staff      Staff?   @relation(fields: [staffId], references: [id])
  student    Student? @relation(fields: [studentId], references: [id])
}

model FinancialRecord {
  id               String        @id @default(uuid())
  studentId        String        @unique
  annualTuition    Decimal?      @db.Decimal(12, 2)
  totalDiscount    Decimal?      @default(0) @db.Decimal(12, 2)
  netTuition       Decimal?      @db.Decimal(12, 2)
  term1Amount      Decimal?      @db.Decimal(12, 2)
  term2Amount      Decimal?      @db.Decimal(12, 2)
  term3Amount      Decimal       @default(0) @db.Decimal(12, 2)
  admissionFee     Decimal?      @db.Decimal(12, 2)
  cautionDeposit   Decimal?      @db.Decimal(12, 2)
  computerFee      Decimal?      @db.Decimal(12, 2)
  developmentFee   Decimal?      @db.Decimal(12, 2)
  examFee          Decimal?      @db.Decimal(12, 2)
  feeScheduleId    String?
  labFee           Decimal?      @db.Decimal(12, 2)
  libraryFee       Decimal?      @db.Decimal(12, 2)
  miscellaneousFee Decimal?      @db.Decimal(12, 2)
  paymentType      String?
  sportsFee        Decimal?      @db.Decimal(12, 2)
  transportFee     Decimal?      @db.Decimal(12, 2)
  tuitionFee       Decimal?      @db.Decimal(12, 2)
  feeStructureId   String?
  schoolId         String
  discounts        Discount[]
  feeStructure     FeeStructure? @relation(fields: [feeStructureId], references: [id])
  school           School        @relation(fields: [schoolId], references: [id])
  student          Student       @relation(fields: [studentId], references: [id])
}

model Discount {
  id                 String          @id @default(uuid())
  schoolId           String
  studentFinancialId String
  discountTypeId     String
  amount             Decimal         @db.Decimal(12, 2)
  status             String          @default("Pending")
  discountType       DiscountType    @relation(fields: [discountTypeId], references: [id])
  school             School          @relation(fields: [schoolId], references: [id])
  financialRecord    FinancialRecord @relation(fields: [studentFinancialId], references: [id])
}

model DiscountType {
  id          String     @id @default(uuid())
  name        String     @unique
  amount      Decimal?   @db.Decimal(12, 2)
  description String?
  percentage  Decimal?   @db.Decimal(5, 2)
  schoolId    String
  discounts   Discount[]
  school      School     @relation(fields: [schoolId], references: [id])
}

model FeeStructure {
  id             String            @id @default(uuid())
  structureCode  String?
  branchId       String
  classId        String?
  academicYearId String
  name           String
  schoolId       String
  totalAmount    Decimal           @db.Decimal(12, 2)
  academicYear   AcademicYear      @relation(fields: [academicYearId], references: [id])
  branch         Branch            @relation(fields: [branchId], references: [id])
  class          Class?            @relation(fields: [classId], references: [id])
  school         School            @relation(fields: [schoolId], references: [id])
  students       FinancialRecord[]

  @@unique([schoolId, structureCode])
  @@index([schoolId])
}

model Collection {
  id               String        @id @default(uuid())
  receiptNumber    String
  studentId        String
  financialYearId  String
  schoolId         String
  branchId         String
  amountPaid       Decimal       @db.Decimal(12, 2)
  lateFeePaid      Decimal       @default(0) @db.Decimal(12, 2)
  convenienceFee   Decimal?      @db.Decimal(12, 2)
  totalPaid        Decimal       @db.Decimal(12, 2)
  paymentMode      String
  paymentReference String?
  allocatedTo      Json?
  paymentDate      DateTime      @default(now())
  collectedBy      String
  journalEntryId   String?       @unique
  isAutomated      Boolean       @default(false)
  status           String        @default("Success")
  branch           Branch        @relation(fields: [branchId], references: [id])
  journalEntry     JournalEntry? @relation(fields: [journalEntryId], references: [id])
  school           School        @relation(fields: [schoolId], references: [id])
  student          Student       @relation(fields: [studentId], references: [id])

  @@unique([schoolId, receiptNumber])
  @@index([schoolId])
  @@index([receiptNumber])
}

model ChartOfAccount {
  id             String        @id @default(uuid())
  accountCode    String
  accountName    String
  accountType    String
  currentBalance Decimal       @default(0) @db.Decimal(15, 2)
  schoolId       String
  branchId       String?
  branch         Branch?       @relation(fields: [branchId], references: [id])
  school         School        @relation(fields: [schoolId], references: [id])
  journals       JournalLine[]

  @@unique([schoolId, accountCode])
}

model JournalEntry {
  id              String        @id @default(uuid())
  entryCode       String?
  financialYearId String
  entryDate       DateTime      @default(now())
  entryType       String
  description     String?
  totalDebit      Decimal       @db.Decimal(15, 2)
  totalCredit     Decimal       @db.Decimal(15, 2)
  schoolId        String
  collection      Collection?
  expense         Expense?
  financialYear   FinancialYear @relation(fields: [financialYearId], references: [id])
  school          School        @relation(fields: [schoolId], references: [id])
  lines           JournalLine[]

  @@unique([schoolId, entryCode])
  @@index([schoolId])
}

model JournalLine {
  id             String         @id @default(uuid())
  journalEntryId String
  description    String?
  accountId      String
  credit         Decimal        @default(0) @db.Decimal(15, 2)
  debit          Decimal        @default(0) @db.Decimal(15, 2)
  account        ChartOfAccount @relation(fields: [accountId], references: [id])
  journalEntry   JournalEntry   @relation(fields: [journalEntryId], references: [id])
}

model Expense {
  id               String          @id @default(uuid())
  category         String
  amount           Decimal         @db.Decimal(12, 2)
  description      String?
  journalEntryId   String?         @unique
  paymentRequestId String?         @unique
  journalEntry     JournalEntry?   @relation(fields: [journalEntryId], references: [id])
  paymentRequest   PaymentRequest? @relation(fields: [paymentRequestId], references: [id])
}

model PaymentRequest {
  id            String            @id
  amount        Decimal           @db.Decimal(12, 2)
  status        String            @default("Pending")
  approvalLevel String
  requesterId   String
  expense       Expense?
  approvals     PaymentApproval[]
  execution     PaymentExecution?
}

model PaymentApproval {
  id               String         @id @default(uuid())
  paymentRequestId String
  approverId       String
  status           String
  comments         String?
  createdAt        DateTime       @default(now())
  paymentRequest   PaymentRequest @relation(fields: [paymentRequestId], references: [id])
}

model PaymentExecution {
  id               String         @id @default(uuid())
  paymentRequestId String         @unique
  voucherNumber    String         @unique
  paymentMode      String
  reference        String?
  executedAt       DateTime       @default(now())
  paymentRequest   PaymentRequest @relation(fields: [paymentRequestId], references: [id])
}

model Staff {
  id                 String             @id @default(uuid())
  staffCode          String
  firstName          String
  middleName         String?
  lastName           String
  email              String?
  phone              String?
  dob                DateTime?
  gender             String?
  branchId           String
  schoolId           String
  photoUrl           String?
  status             String             @default("ACTIVE")
  onboardingStatus   String             @default("JOINED")
  userId             String?
  role               String             @default("STAFF")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  passwordHash       String?
  username           String?            @unique
  documents          Document[]
  branch             Branch             @relation(fields: [branchId], references: [id])
  school             School             @relation(fields: [schoolId], references: [id])
  advances           StaffAdvance[]
  attendance         StaffAttendance[]
  bank               StaffBank?
  professional       StaffProfessional?
  statutory          StaffStatutory?
  vehicleAssignments VehicleStaff[]
  salarySlips        SalarySlip[]
  kyc                StaffKYC?
  salaryRevisions    SalaryRevision[]
  assets             StaffAsset[]
  assignedClassId    String?            @unique
  assignedClass      Class?             @relation("ClassTeacher", fields: [assignedClassId], references: [id])

  @@unique([branchId, staffCode])
  @@unique([branchId, email])
  @@unique([branchId, phone])
  @@unique([branchId, userId])
  @@index([schoolId])
}

model StaffProfessional {
  id                 String   @id @default(uuid())
  staffId            String   @unique
  designation        String
  department         String?
  qualification      String?
  experienceYears    Float?
  dateOfJoining      DateTime
  basicSalary        Decimal  @db.Decimal(12, 2)
  daAmount           Decimal  @default(0) @db.Decimal(12, 2)
  isDAEnabled        Boolean  @default(false)
  isESIEnabled       Boolean  @default(false)
  isPFEnabled        Boolean  @default(false)
  hraAmount          Decimal  @default(0) @db.Decimal(12, 2)
  isPTEnabled        Boolean  @default(false)
  specialAllowance   Decimal  @default(0) @db.Decimal(12, 2)
  transportAllowance Decimal  @default(0) @db.Decimal(12, 2)
  casualLeaveBalance Int      @default(0)
  sickLeaveBalance   Int      @default(0)
  hraFormula         String?   
  daFormula          String?   
  otherAllowances    Json?     
  staff              Staff    @relation(fields: [staffId], references: [id])
}

model StaffAdvance {
  id            String   @id @default(uuid())
  staffId       String
  amount        Decimal  @db.Decimal(12, 2)
  balance       Decimal  @db.Decimal(12, 2)
  installment   Decimal  @db.Decimal(12, 2)
  disbursedDate DateTime @default(now())
  status        String   @default("Active")
  reason        String?
  staff         Staff    @relation(fields: [staffId], references: [id])
}

model StaffStatutory {
  id        String  @id @default(uuid())
  staffId   String  @unique
  panNumber String? @unique
  pfNumber  String? @unique
  uanNumber String? @unique
  esiNumber String? @unique
  staff     Staff   @relation(fields: [staffId], references: [id])
}

model StaffBank {
  id            String @id @default(uuid())
  staffId       String @unique
  accountName   String
  accountNumber String
  ifscCode      String
  bankName      String
  staff         Staff  @relation(fields: [staffId], references: [id])
}

model StaffAttendance {
  id       String    @id @default(uuid())
  staffId  String
  date     DateTime
  status   String
  checkIn  DateTime?
  checkOut DateTime?
  staff    Staff     @relation(fields: [staffId], references: [id])
}

model StudentAttendance {
  id        String    @id @default(uuid())
  studentId String
  date      DateTime  @default(now())
  status    String    @default("Present")
  remarks   String?
  schoolId  String
  classId   String?
  entryTime DateTime?
  sectionId String?
  session   String    @default("Morning")
  class     Class?    @relation(fields: [classId], references: [id])
  school    School    @relation(fields: [schoolId], references: [id])
  section   Section?  @relation(fields: [sectionId], references: [id])
  student   Student   @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([date])
}

model Route {
  id          String                       @id @default(uuid())
  routeName   String
  routeCode   String                       @unique
  schoolId    String
  branchId    String?
  branch      Branch?                      @relation("BranchRoutes", fields: [branchId], references: [id])
  school      School                       @relation(fields: [schoolId], references: [id])
  assignments StudentTransportAssignment[]
  vehicles    Vehicle[]
  stops       VehicleStop[]

  @@index([branchId])
}

model Vehicle {
  id             String         @id @default(uuid())
  registrationNo String         @unique
  model          String?
  capacity       Int
  routeId        String
  branchId       String?
  branch         Branch?        @relation("BranchVehicles", fields: [branchId], references: [id])
  route          Route          @relation(fields: [routeId], references: [id])
  staff          VehicleStaff[]

  @@index([branchId])
}

model VehicleStop {
  id                String                       @id @default(uuid())
  routeId           String
  stopName          String
  pickupTime        String?
  dropTime          String?
  monthlyFee        Decimal                      @db.Decimal(10, 2)
  branchId          String?
  branch            Branch?                      @relation("BranchStops", fields: [branchId], references: [id])
  dropAssignments   StudentTransportAssignment[] @relation("DropStop")
  pickupAssignments StudentTransportAssignment[] @relation("PickupStop")
  route             Route                        @relation(fields: [routeId], references: [id])

  @@index([branchId])
}

model VehicleStaff {
  id        String  @id @default(uuid())
  vehicleId String
  staffId   String
  role      String
  staff     Staff   @relation(fields: [staffId], references: [id])
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])
}

model StudentTransportAssignment {
  id           String      @id @default(uuid())
  studentId    String      @unique
  dropStopId   String
  monthlyFee   Decimal     @db.Decimal(10, 2)
  pickupStopId String
  routeId      String
  schoolId     String
  status       String      @default("Active")
  dropStop     VehicleStop @relation("DropStop", fields: [dropStopId], references: [id])
  pickupStop   VehicleStop @relation("PickupStop", fields: [pickupStopId], references: [id])
  route        Route       @relation(fields: [routeId], references: [id])
  school       School      @relation(fields: [schoolId], references: [id])
  student      Student     @relation(fields: [studentId], references: [id])
}

model Subject {
  id          String       @id @default(uuid())
  name        String
  code        String       @unique
  classId     String?
  schoolId    String
  branchId    String?
  examResults ExamResult[]
  branch      Branch?      @relation("BranchSubjects", fields: [branchId], references: [id])
  class       Class?       @relation(fields: [classId], references: [id])
  school      School       @relation(fields: [schoolId], references: [id])

  @@index([branchId])
}

model ExamType {
  id           String       @id @default(uuid())
  name         String
  academicYear String
  schoolId     String
  branchId     String?
  results      ExamResult[]
  branch       Branch?      @relation("BranchExamTypes", fields: [branchId], references: [id])
  school       School       @relation(fields: [schoolId], references: [id])

  @@index([branchId])
}

model GradeScale {
  id       String @id @default(uuid())
  grade    String
  minScore Int
  maxScore Int
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])
}

model ExamResult {
  id            String   @id @default(uuid())
  studentId     String
  examTypeId    String
  subjectId     String
  marksObtained Decimal  @db.Decimal(5, 2)
  totalMarks    Decimal  @db.Decimal(5, 2)
  remarks       String?
  schoolId      String
  branchId      String?
  passMarks     Decimal  @default(33) @db.Decimal(5, 2)
  branch        Branch?  @relation("BranchExamResults", fields: [branchId], references: [id])
  examType      ExamType @relation(fields: [examTypeId], references: [id])
  school        School   @relation(fields: [schoolId], references: [id])
  student       Student  @relation(fields: [studentId], references: [id])
  subject       Subject  @relation(fields: [subjectId], references: [id])

  @@index([branchId])
}

model Book {
  id          String        @id @default(uuid())
  accessionId String        @unique
  title       String
  author      String?
  isbn        String?
  category    String?
  status      String        @default("Available")
  branchId    String?
  branch      Branch?       @relation("BranchBooks", fields: [branchId], references: [id])
  issues      IssueReturn[]

  @@index([branchId])
}

model LibraryMember {
  id           String        @id @default(uuid())
  studentId    String        @unique
  membershipId String        @unique
  branchId     String?
  branch       Branch?       @relation("BranchLibraryMembers", fields: [branchId], references: [id])
  issues       IssueReturn[]
  student      Student       @relation(fields: [studentId], references: [id])

  @@index([branchId])
}

model IssueReturn {
  id         String        @id @default(uuid())
  bookId     String
  memberId   String
  issueDate  DateTime      @default(now())
  dueDate    DateTime
  returnDate DateTime?
  status     String        @default("Issued")
  branchId   String?
  branch     Branch?       @relation("BranchLibraryIssues", fields: [branchId], references: [id])
  book       Book          @relation(fields: [bookId], references: [id])
  member     LibraryMember @relation(fields: [memberId], references: [id])

  @@index([branchId])
}

model BiometricTemplate {
  id           String @id @default(uuid())
  personId     String @unique
  templateData String
  personType   String
}

model Notification {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  message   String
  recipient String
  schoolId  String
  branchId  String?
  status    String   @default("Pending")
  type      String
  branch    Branch?  @relation("BranchNotifications", fields: [branchId], references: [id])
  school    School   @relation(fields: [schoolId], references: [id])

  @@index([branchId])
}

model TenancyCounter {
  id        String @id @default(uuid())
  schoolId  String
  branchId  String @default("GLOBAL")
  type      String
  year      String
  lastValue Int    @default(0)
  school    School @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, branchId, type, year])
}

model Enquiry {
  id               String   @id @default(uuid())
  schoolId         String
  studentFirstName String
  studentLastName  String?
  parentName       String
  parentPhone      String
  parentEmail      String?
  requestedClass   String
  academicYear     String
  previousSchool   String?
  notes            String?
  status           String   @default("Pending")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  referredBy       String?
  referrerPhone    String?
  branchId         String?
  branch           Branch?  @relation("BranchEnquiries", fields: [branchId], references: [id])
  school           School   @relation(fields: [schoolId], references: [id])

  @@index([branchId])
}

model GlobalSetting {
  id        String   @id @default(uuid())
  schoolId  String
  key       String
  value     String
  isSecret  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, key])
}

model StudentConsent {
  id             String       @id @default(uuid())
  studentId      String
  academicYearId String
  consentStatus  String       @default("Pending")
  updatedPhone   String?
  updatedAddress String?
  submittedAt    DateTime?
  token          String       @unique @default(uuid())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  student        Student      @relation(fields: [studentId], references: [id])

  @@unique([studentId, academicYearId])
}

model ActivityLog {
  id         String   @id @default(uuid())
  schoolId   String
  userId     String
  entityType String
  entityId   String
  action     String
  details    String?
  ipAddress  String?
  branchId   String?
  createdAt  DateTime @default(now())
  branch     Branch?  @relation("BranchLogs", fields: [branchId], references: [id])
  school     School   @relation(fields: [schoolId], references: [id])

  @@index([branchId])
}

model PayrollRun {
  id            String       @id @default(uuid())
  schoolId      String
  month         Int
  year          Int
  status        String       @default("Draft") // Draft, Reviewed, Approved, Paid
  totalGross    Decimal      @db.Decimal(15, 2)
  totalNet      Decimal      @db.Decimal(15, 2)
  processedBy   String?
  processedAt   DateTime?
  approvedBy    String?
  approvedAt    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  branchId      String?
  branch        Branch?      @relation("BranchPayroll", fields: [branchId], references: [id])
  school        School       @relation(fields: [schoolId], references: [id])
  slips         SalarySlip[]

  @@unique([schoolId, month, year])
  @@index([branchId])
}

model SalarySlip {
  id               String     @id @default(uuid())
  payrollRunId     String
  staffId          String
  totalWorkingDays Int?       
  attendedDays     Float?     
  paidLeaves       Float?     @default(0) 
  lwpDays          Float?     @default(0)
  payableDays      Float?     

  baseAmount       Decimal    @db.Decimal(12, 2)
  arrears          Decimal    @default(0) @db.Decimal(12, 2)
  allowances       Json?      // e.g. {hra: 1000, da: 500}
  deductions       Json?      // e.g. {pf: 150, unpaid_leave_deduction: 500}
  snapshot         Json       // Fully frozen map of `StaffProfessional` components at generation
  
  grossSalary      Decimal    @db.Decimal(12, 2)
  netSalary        Decimal    @db.Decimal(12, 2)
  
  status           String     @default("Draft") // Draft, Reviewed, Approved, Paid
  version          Int        @default(1)
  paymentStatus    String     @default("PENDING")
  hash             String?    // SHA256 of net configurations to prevent historic tamper edits
  
  paymentMode      String?
  paymentRef       String?
  paidAt           DateTime?
  branchId         String?
  branch           Branch?    @relation("BranchSlips", fields: [branchId], references: [id])
  payrollRun       PayrollRun @relation(fields: [payrollRunId], references: [id])
  staff            Staff      @relation(fields: [staffId], references: [id])

  // Prevent multi-user collision/overwrite bugs during Draft phase
  updatedAt        DateTime   @default(now()) @updatedAt

  @@unique([payrollRunId, staffId])
  @@index([branchId])
}

model StaffKYC {
  id              String    @id @default(uuid())
  staffId         String    @unique
  aadhaarNumber   String?   @unique
  panNumber       String?   @unique
  aadhaarStatus   String    @default("PENDING")
  panStatus       String    @default("PENDING")
  overallStatus   String    @default("PENDING")
  verifiedAt      DateTime?
  verifiedBy      String?
  staff           Staff     @relation(fields: [staffId], references: [id])
}

model SalaryRevision {
  id              String   @id @default(uuid())
  staffId         String
  previousSalary  Decimal  @db.Decimal(12, 2)
  newSalary       Decimal  @db.Decimal(12, 2)
  effectiveDate   DateTime
  reason          String?
  approvedBy      String?
  createdAt       DateTime @default(now())
  staff           Staff    @relation(fields: [staffId], references: [id])
}

model StaffAsset {
  id          String    @id @default(uuid())
  staffId     String
  assetName   String
  assetType   String
  identifier  String?   // Serial #, etc.
  issuedDate  DateTime  @default(now())
  returnedDate DateTime?
  status      String    @default("ISSUED") // ISSUED, RETURNED, DAMAGED
  staff       Staff     @relation(fields: [staffId], references: [id])
}

enum EmploymentStatus {
  ACTIVE
  ON_LEAVE
  RESIGNED
  TERMINATED
}

enum OnboardingStatus {
  OFFERED
  ACCEPTED
  JOINED
}

enum KYCStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PROCESSED
  FAILED
}

enum ExitType {
  RESIGNATION
  TERMINATION
  RETIREMENT
}
