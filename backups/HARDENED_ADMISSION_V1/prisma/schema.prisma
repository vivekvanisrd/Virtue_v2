generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id                    String                       @id
  name                  String
  code                  String                       @unique
  address               String?
  phone                 String?
  email                 String?
  logo                  String?
  highestClass          String?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  status                String                       @default("Active")
  dnaVersion            String                       @default("v1")
  isGenesis             Boolean                      @default(false)
  metadata              Json?
  tenantId              String?
  academicHist          AcademicHistory[]
  academicRecs          AcademicRecord[]
  academicYears         AcademicYear[]
  activityLogs          ActivityLog[]
  Address               Address[]
  BankDetail            BankDetail[]
  branches              Branch[]
  accounts              ChartOfAccount[]
  Class                 Class[]
  collections           Collection[]
  creditNotes           CreditNote[]
  discounts             Discount[]
  discountTypes         DiscountType[]
  docRecords            Document[]
  enquiries             Enquiry[]
  examResults           ExamResult[]
  examTypes             ExamType[]
  FamilyDetail          FamilyDetail[]
  feeComponents         FeeComponentMaster[]
  feeStructures         FeeStructure[]
  feeTemplateComponents FeeTemplateComponent[]
  financialAuditLogs    FinancialAuditLog[]
  finRecords            FinancialRecord[]
  financialYears        FinancialYear[]
  gradeScales           GradeScale[]
  journals              JournalEntry[]
  ledgerEntries         LedgerEntry[]
  MedicalRecord         MedicalRecord[]
  notifications         Notification[]
  payrollRuns           PayrollRun[]
  PreviousSchool        PreviousSchool[]
  routes                Route[]
  SalaryRevision        SalaryRevision[]
  SalarySlip            SalarySlip[]
  Section               Section[]
  SovereignEvent        SovereignEvent[]
  sovereignRoles        SovereignRole[]
  staff                 Staff[]
  StaffAdvance          StaffAdvance[]
  StaffAsset            StaffAsset[]
  StaffAttendance       StaffAttendance[]
  StaffBank             StaffBank[]
  staffCategories       StaffCategory[]
  staffDepartments      StaffDepartment[]
  StaffKYC              StaffKYC[]
  StaffProfessional     StaffProfessional[]
  StaffStatutory        StaffStatutory[]
  students              Student[]
  attendance            StudentAttendance[]
  studentFeeComponents  StudentFeeComponent[]
  transportAssignments  StudentTransportAssignment[]
  subjects              Subject[]
  counters              TenancyCounter[]
  TransportAssignment   TransportAssignment[]
  TransportDetail       TransportDetail[]
  TransportStop         TransportStop[]
  unlockRequests        UnlockRequest[]

  // 🛡️ Shadow Relation for Enterprise V4
  backboneInvoices FeeInvoice[]
}

model PlatformAdmin {
  id                   String                 @id @default(uuid())
  name                 String
  email                String                 @unique
  username             String                 @unique
  passwordHash         String
  metadata             Json?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  PlatformAcademicYear PlatformAcademicYear[]
  PlatformClass        PlatformClass[]
}

model PlatformClass {
  id              String            @id @default(uuid())
  name            String            @unique
  level           Int               @unique
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  platformAdminId String?
  platformAdmin   PlatformAdmin?    @relation(fields: [platformAdminId], references: [id])
  sections        PlatformSection[]
}

model PlatformSection {
  id              String        @id @default(uuid())
  name            String
  platformClassId String
  platformClass   PlatformClass @relation(fields: [platformClassId], references: [id])
}

model PlatformAcademicYear {
  id              String         @id @default(uuid())
  name            String         @unique
  startMonth      Int
  endMonth        Int
  createdAt       DateTime       @default(now())
  platformAdminId String?
  platformAdmin   PlatformAdmin? @relation(fields: [platformAdminId], references: [id])
}

model Branch {
  id                   String                 @id
  schoolId             String
  name                 String
  code                 String
  address              String?
  phone                String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  status               String                 @default("Active")
  isGenesis            Boolean                @default(false)
  dnaVersion           String                 @default("v1")
  source               String?
  mode                 String?
  triggeredBy          String?
  metadata             Json?
  tenantId             String?
  academicHistory      AcademicHistory[]      @relation("BranchHistory")
  academicRecords      AcademicRecord[]
  activityLogs         ActivityLog[]          @relation("BranchLogs")
  Address              Address[]
  BankDetail           BankDetail[]
  books                Book[]                 @relation("BranchBooks")
  school               School                 @relation(fields: [schoolId], references: [id])
  accounts             ChartOfAccount[]
  Class                Class[]
  collections          Collection[]
  Discount             Discount[]
  DiscountType         DiscountType[]
  enquiries            Enquiry[]              @relation("BranchEnquiries")
  examResults          ExamResult[]           @relation("BranchExamResults")
  examTypes            ExamType[]             @relation("BranchExamTypes")
  FamilyDetail         FamilyDetail[]
  ledgerEntries        LedgerEntry[]
  FeeComponentMaster   FeeComponentMaster[]
  feeStructures        FeeStructure[]
  FeeTemplateComponent FeeTemplateComponent[]
  FinancialRecord      FinancialRecord[]
  libraryIssues        IssueReturn[]          @relation("BranchLibraryIssues")
  libraryMembers       LibraryMember[]        @relation("BranchLibraryMembers")
  MedicalRecord        MedicalRecord[]
  notifications        Notification[]         @relation("BranchNotifications")
  payrollRuns          PayrollRun[]           @relation("BranchPayroll")
  PreviousSchool       PreviousSchool[]
  routes               Route[]                @relation("BranchRoutes")
  SalaryRevision       SalaryRevision[]
  salarySlips          SalarySlip[]           @relation("BranchSlips")
  Section              Section[]
  staff                Staff[]
  StaffAdvance         StaffAdvance[]
  StaffAsset           StaffAsset[]
  StaffAttendance      StaffAttendance[]
  StaffBank            StaffBank[]
  StaffKYC             StaffKYC[]
  StaffProfessional    StaffProfessional[]
  StaffStatutory       StaffStatutory[]
  students             Student[]              @relation("BranchStudents")
  StudentFeeComponent  StudentFeeComponent[]
  subjects             Subject[]              @relation("BranchSubjects")
  TransportDetail      TransportDetail[]
  vehicles             Vehicle[]              @relation("BranchVehicles")
  vehicleStops         VehicleStop[]          @relation("BranchStops")
  attendancePolicies   AttendancePolicy[]
  journalEntries       JournalEntry[]
  StudentAttendance    StudentAttendance[]

  @@unique([schoolId, code])
}

model AcademicYear {
  id            String            @id @default(uuid())
  name          String
  startDate     DateTime
  endDate       DateTime
  isCurrent     Boolean           @default(false)
  isLocked      Boolean           @default(false)
  isGenesis     Boolean           @default(false)
  dnaVersion    String            @default("v1")
  source        String?
  mode          String?
  triggeredBy   String?
  metadata      Json?
  createdAt     DateTime          @default(now())
  schoolId      String
  history       AcademicHistory[]
  school        School            @relation(fields: [schoolId], references: [id])
  feeStructures FeeStructure[]
  consents      StudentConsent[]
  ledgerEntries LedgerEntry[]
}

model FinancialYear {
  id            String         @id @default(uuid())
  name          String
  startDate     DateTime
  endDate       DateTime
  isCurrent     Boolean        @default(false)
  isLocked      Boolean        @default(false)
  isGenesis     Boolean        @default(false)
  dnaVersion    String         @default("v1")
  source        String?
  mode          String?
  triggeredBy   String?
  metadata      Json?
  schoolId      String
  school        School         @relation(fields: [schoolId], references: [id])
  journals      JournalEntry[]
  ledgerEntries LedgerEntry[]

  // 🛡️ Shadow Relation for Enterprise V4
  backboneInvoices FeeInvoice[]
}

model Class {
  id              String              @id @default(uuid())
  name            String
  level           Int
  isGenesis       Boolean             @default(false)
  dnaVersion      String              @default("v1")
  source          String?
  mode            String?
  triggeredBy     String?
  schoolId        String
  branchId        String
  history         AcademicHistory[]
  academicRecords AcademicRecord[]
  branch          Branch              @relation(fields: [branchId], references: [id])
  school          School              @relation(fields: [schoolId], references: [id])
  feeStructures   FeeStructure[]
  sections        Section[]
  classTeacher    Staff?              @relation("ClassTeacher")
  attendance      StudentAttendance[]
  subjects        Subject[]
}

model Section {
  id              String              @id @default(uuid())
  name            String
  classId         String
  isGenesis       Boolean             @default(false)
  dnaVersion      String              @default("v1")
  source          String?
  mode            String?
  triggeredBy     String?
  schoolId        String
  branchId        String
  classTeacherId  String?             @unique
  history         AcademicHistory[]
  academicRecords AcademicRecord[]
  branch          Branch              @relation(fields: [branchId], references: [id])
  class           Class               @relation(fields: [classId], references: [id])
  school          School              @relation(fields: [schoolId], references: [id])
  classTeacher    Staff?              @relation("SectionTeacher", fields: [classTeacherId], references: [id])
  attendance      StudentAttendance[]
}

model Student {
  id               String                      @id @default(uuid())
  registrationId   String?                     @unique
  admissionNumber  String?
  studentCode      String?
  firstName        String
  middleName       String?
  lastName         String?
  email            String?
  phone            String?
  dob              DateTime?
  gender           String?
  bloodGroup       String?
  category         String?
  aadhaarNumber    String?
  aadhaarVerified  Boolean                     @default(false)
  motherTongue     String?
  placeOfBirth     String?
  birthCertNo      String?
  usnSrnNumber     String?
  studentPhoto     String?
  minorityStatus   Boolean                     @default(false)
  bplStatus        Boolean                     @default(false)
  disabilityType   String?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  isDeleted        Boolean                     @default(false)
  deletedAt        DateTime?
  schoolId         String?
  branchId         String?
  status           String                      @default("Active")
  history          AcademicHistory[]
  academic         AcademicRecord?
  address          Address?
  bank             BankDetail?
  collections      Collection[]
  creditNotes      CreditNote[]
  documents        Document[]
  examResults      ExamResult[]
  family           FamilyDetail?
  financial        FinancialRecord?
  libraryMember    LibraryMember?
  medical          MedicalRecord?
  previousSchool   PreviousSchool?
  branch           Branch?                     @relation("BranchStudents", fields: [branchId], references: [id])
  school           School?                     @relation(fields: [schoolId], references: [id])
  attendance       StudentAttendance[]
  consents         StudentConsent[]
  transportAssign  StudentTransportAssignment?
  newTransport     TransportAssignment?        @relation("NewTransport")
  transportHistory TransportCollection[]       @relation("TransportHistory")
  transport        TransportDetail?
  unlockRequests   UnlockRequest[]

  // 🛡️ Shadow Relation for Enterprise V4
  backboneInvoices FeeInvoice[]
  ledgerEntries    LedgerEntry[]

  @@unique([schoolId, branchId, studentCode])
  @@unique([schoolId, branchId, admissionNumber])
  @@index([branchId])
  @@index([schoolId])
  @@index([studentCode])
  @@index([registrationId])
}

model AcademicHistory {
  id              String       @id
  studentId       String
  academicYearId  String
  classId         String
  sectionId       String?
  rollNumber      String?
  promotionStatus String
  promotedFrom    String?
  admissionDate   DateTime?
  exitDate        DateTime?
  tcNumber        String?
  leavingReason   String?
  admissionNumber String?
  studentCode     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  isGenesis       Boolean      @default(false)
  role            Role         @default(STAFF)
  ownerScope      OwnerScope   @default(BRANCH_ONLY)
  schoolId        String?
  branchId        String?
  academicYear    AcademicYear @relation(fields: [academicYearId], references: [id])
  branch          Branch?      @relation("BranchHistory", fields: [branchId], references: [id])
  class           Class        @relation(fields: [classId], references: [id])
  school          School?      @relation(fields: [schoolId], references: [id])
  section         Section?     @relation(fields: [sectionId], references: [id])
  student         Student      @relation(fields: [studentId], references: [id])
  collections     Collection[]

  @@unique([studentId, academicYearId])
  @@unique([schoolId, branchId, admissionNumber])
  @@index([branchId])
}

model AcademicRecord {
  id            String   @id @default(uuid())
  studentId     String   @unique
  admissionDate DateTime @default(now())
  academicYear  String
  classId       String?
  sectionId     String?
  branchId      String
  rollNumber    String?
  biometricId   String?
  penNumber     String?
  apaarId       String?
  samagraId     String?
  stsId         String?
  tcNumber      String?
  admissionType String?
  boardingType  String?
  group         String?
  subcategory   String?
  schoolId      String?
  branch        Branch   @relation(fields: [branchId], references: [id])
  class         Class?   @relation(fields: [classId], references: [id])
  school        School?  @relation(fields: [schoolId], references: [id])
  section       Section? @relation(fields: [sectionId], references: [id])
  student       Student  @relation(fields: [studentId], references: [id])
}

model FamilyDetail {
  id                  String  @id @default(uuid())
  studentId           String  @unique
  fatherName          String?
  fatherPhone         String?
  fatherAltPhone      String?
  fatherEmail         String?
  fatherOccupation    String?
  fatherQualification String?
  motherName          String?
  motherPhone         String?
  motherAltPhone      String?
  motherEmail         String?
  motherOccupation    String?
  motherQualification String?
  whatsappNumber      String?
  emergencyName       String?
  emergencyPhone      String?
  emergencyRelation   String?
  fatherAadhaar       String?
  motherAadhaar       String?
  schoolId            String?
  branchId            String?
  branch              Branch? @relation(fields: [branchId], references: [id])
  school              School? @relation(fields: [schoolId], references: [id])
  student             Student @relation(fields: [studentId], references: [id])
}

model Address {
  id               String  @id @default(uuid())
  studentId        String  @unique
  currentAddress   String?
  permanentAddress String?
  city             String?
  state            String?
  country          String? @default("India")
  pincode          String?
  schoolId         String?
  branchId         String?
  branch           Branch? @relation(fields: [branchId], references: [id])
  school           School? @relation(fields: [schoolId], references: [id])
  student          Student @relation(fields: [studentId], references: [id])
}

model TransportDetail {
  id                String   @id @default(uuid())
  studentId         String   @unique
  transportRequired Boolean  @default(false)
  route             String?
  pickupStop        String?
  dropStop          String?
  monthlyFee        Decimal? @db.Decimal(10, 2)
  schoolId          String?
  branchId          String?
  branch            Branch?  @relation(fields: [branchId], references: [id])
  school            School?  @relation(fields: [schoolId], references: [id])
  student           Student  @relation(fields: [studentId], references: [id])
}

model MedicalRecord {
  id                String  @id @default(uuid())
  studentId         String  @unique
  medicalConditions String?
  allergies         String?
  doctorName        String?
  doctorPhone       String?
  schoolId          String?
  branchId          String?
  branch            Branch? @relation(fields: [branchId], references: [id])
  school            School? @relation(fields: [schoolId], references: [id])
  student           Student @relation(fields: [studentId], references: [id])
}

model BankDetail {
  id            String  @id @default(uuid())
  studentId     String  @unique
  accountName   String?
  accountNumber String?
  ifscCode      String?
  bankBranch    String?
  schoolId      String?
  branchId      String?
  branch        Branch? @relation(fields: [branchId], references: [id])
  school        School? @relation(fields: [schoolId], references: [id])
  student       Student @relation(fields: [studentId], references: [id])
}

model PreviousSchool {
  id               String    @id @default(uuid())
  studentId        String    @unique
  schoolName       String?
  previousClass    String?
  tcNumber         String?
  dateOfLeaving    DateTime?
  reasonForLeaving String?
  schoolId         String?
  branchId         String?
  branch           Branch?   @relation(fields: [branchId], references: [id])
  school           School?   @relation(fields: [schoolId], references: [id])
  student          Student   @relation(fields: [studentId], references: [id])
}

model Document {
  id         String   @id @default(uuid())
  studentId  String?
  staffId    String?
  fileName   String
  fileType   String
  fileUrl    String
  uploadedAt DateTime @default(now())
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id])
  staff      Staff?   @relation(fields: [staffId], references: [id])
  student    Student? @relation(fields: [studentId], references: [id])
}

model FinancialRecord {
  id               String                @id @default(uuid())
  studentId        String                @unique
  annualTuition    Decimal?              @db.Decimal(12, 2)
  totalDiscount    Decimal?              @default(0) @db.Decimal(12, 2)
  netTuition       Decimal?              @db.Decimal(12, 2)
  term1Amount      Decimal?              @db.Decimal(12, 2)
  term2Amount      Decimal?              @db.Decimal(12, 2)
  term3Amount      Decimal               @default(0) @db.Decimal(12, 2)
  admissionFee     Decimal?              @db.Decimal(12, 2)
  cautionDeposit   Decimal?              @db.Decimal(12, 2)
  computerFee      Decimal?              @db.Decimal(12, 2)
  developmentFee   Decimal?              @db.Decimal(12, 2)
  examFee          Decimal?              @db.Decimal(12, 2)
  feeScheduleId    String?
  labFee           Decimal?              @db.Decimal(12, 2)
  libraryFee       Decimal?              @db.Decimal(12, 2)
  miscellaneousFee Decimal?              @db.Decimal(12, 2)
  paymentType      String?
  sportsFee        Decimal?              @db.Decimal(12, 2)
  transportFee     Decimal?              @db.Decimal(12, 2)
  tuitionFee       Decimal?              @db.Decimal(12, 2)
  feeStructureId   String?
  schoolId         String?
  branchId         String?
  discounts        Discount[]
  branch           Branch?               @relation(fields: [branchId], references: [id])
  feeStructure     FeeStructure?         @relation(fields: [feeStructureId], references: [id])
  school           School?               @relation(fields: [schoolId], references: [id])
  student          Student               @relation(fields: [studentId], references: [id])
  components       StudentFeeComponent[]
}

model Discount {
  id                 String          @id @default(uuid())
  schoolId           String
  studentFinancialId String
  discountTypeId     String
  amount             Decimal         @db.Decimal(12, 2)
  status             String          @default("Pending")
  authorizerId       String?
  reason             String?
  branchId           String?
  authorizer         Staff?          @relation("DiscountAuthorizer", fields: [authorizerId], references: [id])
  branch             Branch?         @relation(fields: [branchId], references: [id])
  discountType       DiscountType    @relation(fields: [discountTypeId], references: [id])
  school             School          @relation(fields: [schoolId], references: [id])
  financialRecord    FinancialRecord @relation(fields: [studentFinancialId], references: [id])
}

model DiscountType {
  id          String     @id @default(uuid())
  name        String     @unique
  amount      Decimal?   @db.Decimal(12, 2)
  description String?
  percentage  Decimal?   @db.Decimal(5, 2)
  schoolId    String
  branchId    String?
  isActive    Boolean    @default(true)
  discounts   Discount[]
  branch      Branch?    @relation(fields: [branchId], references: [id])
  school      School     @relation(fields: [schoolId], references: [id])
}

model FeeComponentMaster {
  id                String                 @id @default(uuid())
  schoolId          String
  name              String
  type              String                 @default("ANCILLARY")
  amount            Decimal?               @db.Decimal(12, 2)
  description       String?                @db.Text
  isOneTime         Boolean                @default(false)
  isRefundable      Boolean                @default(false)
  accountCode       String?
  isGenesis         Boolean                @default(false)
  dnaVersion        String                 @default("v1")
  source            String?
  triggeredBy       String?
  branchId          String?
  branch            Branch?                @relation(fields: [branchId], references: [id])
  school            School                 @relation(fields: [schoolId], references: [id])
  templateLinks     FeeTemplateComponent[]
  studentComponents StudentFeeComponent[]
  isActive          Boolean                @default(true)

  // 🛡️ Shadow Relation for Enterprise V4
  backboneInvoiceItems FeeInvoiceItem[]

  @@unique([schoolId, branchId, name])
}

model FeeStructure {
  id             String                 @id @default(uuid())
  structureCode  String?
  branchId       String
  classId        String?
  academicYearId String
  name           String
  schoolId       String
  totalAmount    Decimal                @db.Decimal(12, 2)
  isGenesis      Boolean                @default(false)
  dnaVersion     String                 @default("v1")
  source         String?
  mode           String?
  triggeredBy    String?
  description    String?                @db.Text
  isActive       Boolean                @default(true)
  academicYear   AcademicYear           @relation(fields: [academicYearId], references: [id])
  branch         Branch                 @relation(fields: [branchId], references: [id])
  class          Class?                 @relation(fields: [classId], references: [id])
  school         School                 @relation(fields: [schoolId], references: [id])
  components     FeeTemplateComponent[]
  students       FinancialRecord[]
  ledgerEntries  LedgerEntry[]

  @@unique([schoolId, structureCode])
  @@index([schoolId])
}

model FeeTemplateComponent {
  id              String             @id @default(uuid())
  schoolId        String?
  branchId        String?
  templateId      String
  componentId     String
  amount          Decimal            @db.Decimal(12, 2)
  scheduleType    String             @default("ONE_TIME")
  branch          Branch?            @relation(fields: [branchId], references: [id])
  masterComponent FeeComponentMaster @relation(fields: [componentId], references: [id])
  school          School?            @relation(fields: [schoolId], references: [id])
  template        FeeStructure       @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model StudentFeeComponent {
  id                 String   @id @default(uuid())
  schoolId           String?
  branchId           String?
  studentFinancialId String
  componentId        String
  baseAmount         Decimal  @db.Decimal(12, 2)
  waiverAmount       Decimal  @default(0) @db.Decimal(12, 2)
  discountAmount     Decimal  @default(0) @db.Decimal(12, 2)
  isApplicable       Boolean  @default(true)
  waiverReason       String?
  authorizerId       String?
  lastModifiedAt     DateTime @updatedAt

  // 🔒 Sovereign Lockdown Fields (Enterprise V4)
  isLocked   Boolean   @default(false)
  lockedAt   DateTime?
  lockReason String?   @default("ADMISSION")
  version    Int       @default(1)

  authorizer      Staff?             @relation(fields: [authorizerId], references: [id])
  branch          Branch?            @relation(fields: [branchId], references: [id])
  masterComponent FeeComponentMaster @relation(fields: [componentId], references: [id])
  school          School?            @relation(fields: [schoolId], references: [id])
  financialRecord FinancialRecord    @relation(fields: [studentFinancialId], references: [id])
}

model LedgerEntry {
  id              String   @id @default(uuid())
  studentId       String
  schoolId        String
  branchId        String?
  type            String // CHARGE | PAYMENT | DISCOUNT | ADJUSTMENT
  amount          Decimal  @db.Decimal(12, 2)
  reason          String
  createdBy       String // The Staff ID/Session ID who performed the action
  createdAt       DateTime @default(now())
  academicYearId  String?
  financialYearId String?

  student       Student        @relation(fields: [studentId], references: [id])
  school        School?        @relation(fields: [schoolId], references: [id])
  branch        Branch?        @relation(fields: [branchId], references: [id])
  academicYear  AcademicYear?  @relation(fields: [academicYearId], references: [id])
  financialYear FinancialYear? @relation(fields: [financialYearId], references: [id])

  journalEntryId String?
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])

  feeStructureId String?
  feeStructure   FeeStructure? @relation(fields: [feeStructureId], references: [id])

  @@index([studentId])
  @@index([schoolId])
  @@index([branchId])
}

model FeeInvoice {
  id              String   @id @default(uuid())
  invoiceNumber   String?  @unique
  studentId       String
  academicYearId  String
  financialYearId String
  totalAmount     Decimal  @db.Decimal(12, 2)
  paidAmount      Decimal  @default(0) @db.Decimal(12, 2)
  balance         Decimal  @db.Decimal(12, 2)
  dueDate         DateTime
  status          String   @default("PENDING") // PENDING, PARTIAL, PAID, VOID
  isLocked        Boolean  @default(false)
  generatedAt     DateTime @default(now())
  schoolId        String
  branchId        String

  items       FeeInvoiceItem[]
  allocations CollectionAllocation[]

  school        School        @relation(fields: [schoolId], references: [id])
  financialYear FinancialYear @relation(fields: [financialYearId], references: [id])
  student       Student       @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([schoolId])
}

model FeeInvoiceItem {
  id            String  @id @default(uuid())
  invoiceId     String
  componentId   String?
  componentName String
  componentType String  @default("TUTION") // TUTION, TRANSPORT, LATE_FEE, etc.
  amount        Decimal @db.Decimal(12, 2)
  paidAmount    Decimal @default(0) @db.Decimal(12, 2)
