  branchId  String?
  studentId String
  school    School? @relation(fields: [schoolId], references: [id])
  student   Student @relation(fields: [studentId], references: [id])
}

model TransportCollection {
  id        String  @id @default(uuid())
  studentId String
  amount    Decimal @db.Decimal(12, 2)
  month     Int
  year      Int
  student   Student @relation("TransportHistory", fields: [studentId], references: [id])
}

model StaffDepartment {
  id       String  @id @default(uuid())
  name     String
  schoolId String
  staff    Staff[]
  school   School  @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, name])
}

model StaffCategory {
  id       String  @id @default(uuid())
  name     String
  schoolId String
  staff    Staff[]
  school   School  @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, name])
}

enum Role {
  STAFF
  OWNER
  PRINCIPAL
  TEACHER
  CLERK
  DRIVER
  ATTENDANT
  CUSTOM
}

enum OwnerScope {
  GLOBAL
  BRANCH_ONLY
}

model AttendancePolicy {
  id             String  @id @default(uuid())
  branchId       String
  name           String  @default("Default")
  startMinutes   Int // 8:30 = 510
  endMinutes     Int // 16:30 = 990
  gracePeriod    Int
  halfDayMinutes Int
  weeklyOffs     Int[]   @default([0]) // 0 = Sunday
  autoHoliday    Boolean @default(true)
  branch         Branch  @relation(fields: [branchId], references: [id])
  staff          Staff[]
}

model AttendanceException {
  id      String   @id @default(uuid())
  staffId String
  date    DateTime
  type    String // Late-In, Early-Out, Missing-Checkout
  meta    Json
  staff   Staff    @relation(fields: [staffId], references: [id])
}

model StaffFaceProfile {
  id       String @id @default(uuid())
  staffId  String @unique
  faceId   String
  metadata Json?
  staff    Staff  @relation(fields: [staffId], references: [id])
}
