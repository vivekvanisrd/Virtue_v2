{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "src/app/admin",
    "src/app/admin/**/*",
    "backups",
    "backups/**/*",
    "backup",
    "backup/**/*",
    "scratch",
    "scratch/**/*",
    "src/archive",
    "src/archive/**/*",
    "src/components/finance/deprecated",
    "src/components/finance/deprecated/**/*",
    "src/lib/actions/deprecated",
    "src/lib/actions/deprecated/**/*",
    "src/scripts",
    "scripts",
    "tmp",
    "verify-finance.ts",
    "verify-tenancy.ts",
    "prisma/seed.ts",
    "test-*.ts",
    "verify-*.ts",
    "get_users.ts",
    "audit.ts",
    "temp_*.ts"
  ]
}
